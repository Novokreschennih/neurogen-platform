{
	"name": "eleventy-base-blog",
	"version": "9.0.0",
	"description": "A starter repository for a blog web site using the Eleventy site generator.",
	"type": "module",
	"scripts": {
		"build": "tailwindcss -i ./src/css/input.css -o ./src/css/style.css && npx @11ty/eleventy",
		"start": "tailwindcss -i ./src/css/input.css -o ./src/css/style.css --watch & npx @11ty/eleventy --serve --quiet",
		"build-nocolor": "cross-env NODE_DISABLE_COLORS=1 npm run build",
		"debug": "cross-env DEBUG=Eleventy* npm run build",
		"benchmark": "cross-env DEBUG=Eleventy:Benchmark* npm run build"
	},
	"repository": {
		"type": "git",
		"url": "git://github.com/11ty/eleventy-base-blog.git"
	},
	"author": {
		"name": "Zach Leatherman",
		"email": "zachleatherman@gmail.com",
		"url": "https://zachleat.com/"
	},
	"license": "MIT",
	"engines": {
		"node": ">=18"
	},
	"funding": {
		"type": "opencollective",
		"url": "https://opencollective.com/11ty"
	},
	"bugs": {
		"url": "https://github.com/11ty/eleventy-base-blog/issues"
	},
	"homepage": "https://github.com/11ty/eleventy-base-blog#readme",
	"devDependencies": {
		"@11ty/eleventy": "^3.1.2",
		"@11ty/eleventy-img": "^6.0.4",
		"@11ty/eleventy-navigation": "^1.0.4",
		"@11ty/eleventy-plugin-rss": "^2.0.4",
		"@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
		"@tailwindcss/cli": "^4.2.2",
		"cross-env": "^7.0.3",
		"eleventy-plugin-images-responsiver": "^3.0.0",
		"html-minifier-terser": "^7.2.0",
		"luxon": "^3.6.1",
		"prismjs": "^1.30.0",
		"tailwindcss": "^4.2.2",
		"zod": "^3.25.67",
		"zod-validation-error": "^3.5.2"
	},
	"dependencies": {
		"@zachleat/heading-anchors": "^1.0.3",
		"fuse.js": "^7.1.0"
	}
}
