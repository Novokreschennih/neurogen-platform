                    document.getElementById("status-badge").textContent = "3 ДНЯ";
                    document.getElementById("status-icon").textContent = "⏳";
                } else {
                    sb.className = "p-4 rounded-2xl border border-cyan-500/30 bg-cyan-500/5 flex items-center justify-between";
