                      <option value="polza">Polza.ai (РФ, Карты)</option>
                      <option value="openrouter">OpenRouter (Крипта)</option>
                    </select>
                  </div>

                  <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase">Модель нейросети:</label>
                    <select id="ai-model" class="w-full mt-1 p-3 rounded-xl text-sm outline-none bg-black/50 border border-white/10 text-white">
                      <!-- Динамически заполняется JS -->
                    </select>
                  </div>

                  <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase flex justify-between">
                      <span>Свой API Ключ (безлимит):</span>
                      <a href="https://sethubble.ru/go-polza.html" target="_blank" class="text-cyan-400 hover:underline flex items-center gap-1">Получить ключ ↗</a>
                    </label>
                    <input type="password" id="ai-api-key" placeholder="sk-..." class="w-full mt-1 p-3 rounded-xl text-sm outline-none bg-black/50 border border-white/10 focus:border-cyan-500 text-white">
                  </div>

                  <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase">Лимит ответов (на 1 юзера):</label>
                    <input type="number" id="ai-limit" placeholder="0 = по умолчанию" class="w-full mt-1 p-3 rounded-xl text-sm outline-none bg-black/50 border border-white/10 focus:border-cyan-500 text-white">
                  </div>
                </div>

                <!-- КОНСТРУКТОР ХАРАКТЕРА -->
                <div class="glass-panel p-5 rounded-2xl space-y-4">
                  <h4 class="text-xs font-bold text-cyan-400 uppercase tracking-wider mb-2">🎭 Конструктор промпта</h4>
                  
                  <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase">Роль ИИ:</label>
                    <input type="text" id="ui-role" oninput="compilePrompt()" placeholder="Например: Эксперт по инвестициям" class="w-full mt-1 p-3 rounded-xl text-sm outline-none bg-black/50 border border-white/10 text-white">
                  </div>
                  
                  <div class="grid grid-cols-2 gap-3">
                    <div>
                      <label class="text-[10px] font-bold text-gray-400 uppercase">Стиль общения:</label>
                      <select id="ui-tone" onchange="compilePrompt()" class="w-full mt-1 p-3 rounded-xl text-sm outline-none bg-black/50 border border-white/10 text-white">
                        <option value="Уверенный, давит на выгоду">Уверенный (Продажи)</option>
                        <option value="Эмпатичный, задает вопросы">Заботливый (Эмпатия)</option>
                        <option value="Сухой, оперирует цифрами">Технический (Факты)</option>
                        <option value="Ироничный, использует реверсивную психологию">Дерзкий (Ирония)</option>
                      </select>
                    </div>
                    <div>
                      <label class="text-[10px] font-bold text-gray-400 uppercase">Главная цель:</label>
                      <select id="ui-goal" onchange="compilePrompt()" class="w-full mt-1 p-3 rounded-xl text-sm outline-none bg-black/50 border border-white/10 text-white">
                        <option value="Продать PRO-статус">Продать PRO</option>
                        <option value="Убедить зарегистрироваться в системе">Регистрация</option>
                        <option value="Закрыть на личный созвон с менеджером">Назначить созвон</option>
                      </select>
                    </div>
                  </div>

                  <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase">Возражение "Дорого / Подумаю":</label>
                    <input type="text" id="ui-objection" oninput="compilePrompt()" placeholder="Бей в упущенную прибыль..." class="w-full mt-1 p-3 rounded-xl text-sm outline-none bg-black/50 border border-white/10 text-white">
                  </div>

                  <!-- Скрытое поле оригинального промпта для API -->
                  <textarea id="ai-prompt-hidden" class="hidden"></textarea>

                  <button onclick="saveAiSettings()" id="saveAiBtn" class="w-full bg-gradient-to-r from-cyan-500 to-purple-600 py-4 rounded-xl font-bold text-sm shadow-lg active:scale-95 transition-all text-white mt-4">
                    💾 СОХРАНИТЬ ИНТЕЛЛЕКТ
                  </button>
                </div>
              </div>

              <!-- ПРАВАЯ КОЛОНКА: ТЕСТОВЫЙ ЧАТ -->
              <div class="h-full">
                <div class="glass-panel rounded-3xl p-1 flex flex-col h-[600px] border-gray-700">
                  <div class="p-4 border-b border-white/5 flex items-center justify-between bg-black/40 rounded-t-3xl">
                    <div class="flex items-center gap-2">
                      <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
                      <span class="text-xs font-bold text-white uppercase tracking-wider">Тестовый полигон</span>
                    </div>
                    <span class="text-[9px] text-gray-500">Сохраните перед тестом</span>
                  </div>
                  
                  <div id="testChatArea" class="flex-1 overflow-y-auto p-4 space-y-4 chat-scroll flex flex-col">
                    <div class="bg-gray-800/80 text-gray-200 text-sm p-3 rounded-2xl rounded-tl-sm max-w-[85%] self-start">
                      Привет! Я готов к тестированию. Примени пресет, нажми "Сохранить", а затем напиши мне что-нибудь.
                    </div>
                  </div>

                  <div class="p-3 bg-black/40 border-t border-white/5 rounded-b-3xl">
                    <div class="flex items-end gap-2">
                      <textarea id="testChatInput" rows="1" placeholder="Введите сообщение..." class="flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white outline-none focus:border-cyan-500 resize-none h-[46px]"></textarea>
                      <button onclick="sendTestMessage()" id="testSendBtn" class="bg-cyan-600 hover:bg-cyan-500 text-white w-[46px] h-[46px] rounded-xl flex items-center justify-center transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"></path></svg>
                      </button>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>

      </div>
    </div>

    <script>
      // =========================================================================
      // ИНИЦИАЛИЗАЦИЯ И СТАТУС
      // =========================================================================
      let tg = null;
      try { tg = window.Telegram?.WebApp; if(tg) { tg.expand(); tg.ready(); } } catch(e) {}

      let userData = null;
      let refLink = "";
      let b2bRefLink = "";
      let currentLinkMode = "online";
      let authHeaders = { "Content-Type": "application/json" };
      let webAppJwt = ""; // Сохраняем JWT локально

      const urlParamsAPI = new URLSearchParams(window.location.search);
      const BACKEND_URL = urlParamsAPI.get("api") || "https://d5dsbah1d4ju0glmp9d0.3zvepvee.apigw.yandexcloud.net";

      function showToast(message, type = "success") {
        const c = document.getElementById("toast-container");
        const t = document.createElement("div");
        t.className = `toast ${type}`;
        t.innerHTML = (type === "success" ? "✅ " : type === "error" ? "❌ " : "ℹ️ ") + message;
        c.appendChild(t);
        setTimeout(() => t.classList.add("show"), 10);
        setTimeout(() => { t.classList.remove("show"); setTimeout(() => t.remove(), 300); }, 3000);
      }

      function switchTab(tab) {
        document.getElementById("content-marketing").classList.toggle("hidden", tab !== 'marketing');
        document.getElementById("content-ai").classList.toggle("hidden", tab !== 'ai');
        document.getElementById("tab-marketing").className = tab === 'marketing' ? "pb-2 tab-active transition-all" : "pb-2 text-gray-500 transition-all";
        document.getElementById("tab-ai").className = tab === 'ai' ? "pb-2 tab-active transition-all" : "pb-2 text-gray-500 transition-all";
        if(tg?.HapticFeedback) tg.HapticFeedback.impactOccurred("light");
      }

      async function initUser() {
        const urlParams = new URLSearchParams(window.location.search);
        const urlToken = urlParams.get("token");

        if (urlToken && urlToken !== "undefined" && urlToken !== "null") {
          authHeaders["Authorization"] = `Bearer ${urlToken}`;
          localStorage.setItem("neurogen_jwt", urlToken);
          webAppJwt = urlToken; // Сохраняем для CRM
          
          try {
            const cleanParams = new URLSearchParams(window.location.search);
            cleanParams.delete("token");
            const searchString = cleanParams.toString();
            const newUrl = window.location.pathname + (searchString ? "?" + searchString : "");
            window.history.replaceState({}, document.title, newUrl);
          } catch(e) {}
        } else if (localStorage.getItem("neurogen_jwt")) {
          const storedToken = localStorage.getItem("neurogen_jwt");
          authHeaders["Authorization"] = `Bearer ${storedToken}`;
          webAppJwt = storedToken;
        } else if (tg?.initData) {
          authHeaders["x-telegram-initdata"] = tg.initData;
        } else {
          document.getElementById("loadingBlock").innerHTML = "<div class='text-red-400 text-sm'>⚠️ ОШИБКА АВТОРИЗАЦИИ</div>";
          return;
        }

        try {
          const response = await fetch(`${BACKEND_URL}/?action=get_partner_link`, {
            method: "POST", headers: authHeaders, body: JSON.stringify({ action: "get_partner_link" })
          });
          if (!response.ok) throw new Error("Сессия истекла");
          
          const data = await response.json();
          if (data.success) {
            userData = data.user;
            refLink = data.refLink;
            b2bRefLink = data.b2bRefLink || null;
            initUI();
          } else throw new Error(data.error);
        } catch (error) {
          document.getElementById("loadingBlock").innerHTML = `<div class='text-red-400 text-sm'>⚠️ ${error.message}</div>`;
        }
      }

      // =========================================================================
      // РЕНДЕР ИНТЕРФЕЙСА
      // =========================================================================
      function initUI() {
        document.getElementById("loadingBlock").classList.add("hidden");
        document.getElementById("mainContent").classList.remove("hidden");

        if (userData.first_name) {
          document.getElementById("userAvatar").textContent = userData.first_name[0].toUpperCase();
          document.getElementById("userAvatar").style.backgroundImage = "none";
        }

        // Дашборд
        document.getElementById("statClicks").textContent = userData.clicks || 0;
        document.getElementById("statLeads").textContent = userData.referrals || 0;
        document.getElementById("statEarnings").textContent = "$" + (userData.earnings || "0.00");

        // FREE / PRO Блоки
        if (userData.is_pro) {
          document.getElementById("tariff-pro").classList.remove("hidden");
          document.getElementById("tariff-free").classList.add("hidden");
          // Настраиваем ссылку на CRM
          const crmUrl = "https://novokreschennih.github.io/crm-dashboard/";
          document.getElementById("openCrmBtn").onclick = () => {
            // Передаем тот же JWT токен, с которым мы зашли
            window.open(`${crmUrl}?token=${webAppJwt}`, "_blank");
          };
        } else {
          document.getElementById("tariff-free").classList.remove("hidden");
          document.getElementById("tariff-pro").classList.add("hidden");
        }

        // Инициализация ссылок и QR
        setLinkMode('online');

        // === ИИ СТАТУС ===
        const now = Date.now();
        const aiUntil = parseInt(userData.ai_active_until) || 0;
        const isAiActive = aiUntil > now;

        const sb = document.getElementById("ai-status-banner");
        const sTitle = document.getElementById("status-title");
        const sDate = document.getElementById("status-date");
        const sBadge = document.getElementById("status-badge");
        const sIcon = document.getElementById("status-icon");

        if (isAiActive) {
          document.getElementById("ai-constructor").classList.remove("hidden");
          document.getElementById("ai-paywall").classList.add("hidden");

          const daysLeft = Math.ceil((aiUntil - now) / 86400000);
          const fDate = new Date(aiUntil).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long' });

          if (daysLeft <= 3) {
            sb.className = "mb-6 p-4 rounded-2xl border border-yellow-500/30 bg-yellow-500/5 flex items-center justify-between";
            sTitle.textContent = "Пробный период (Trial)";
            sTitle.className = "text-xs font-bold text-yellow-400 uppercase tracking-wider";
            sDate.textContent = `Доступ закроется ${fDate}`;
            sBadge.textContent = "3 ДНЯ БЕСПЛАТНО";
            sBadge.className = "px-3 py-1 rounded-full text-[10px] font-black uppercase bg-yellow-500 text-black";
            sIcon.textContent = "🎁";
          } else {
            sb.className = "mb-6 p-4 rounded-2xl border border-cyan-500/30 bg-cyan-500/5 flex items-center justify-between";
            sTitle.textContent = "Интеллект активен";
            sTitle.className = "text-xs font-bold text-cyan-400 uppercase tracking-wider";
            sDate.textContent = `Подписка активна до ${fDate}`;
            sBadge.textContent = "PREMIUM";
            sBadge.className = "px-3 py-1 rounded-full text-[10px] font-black uppercase bg-cyan-500 text-black";
            sIcon.textContent = "🚀";
          }
        } else {
          document.getElementById("ai-constructor").classList.add("hidden");
          document.getElementById("ai-paywall").classList.remove("hidden");
        }

        // === ИИ НАСТРОЙКИ ===
        if (userData.ai_provider) document.getElementById("ai-provider").value = userData.ai_provider;
        updateModelsList(userData.ai_model); // Заполняем список моделей
        if (userData.user_daily_limit) document.getElementById("ai-limit").value = userData.user_daily_limit;
        
        // Восстановление UI стейта из бэкенда
        if (userData.ai_ui_state) {
          const state = userData.ai_ui_state;
          if(state.role) document.getElementById("ui-role").value = state.role;
          if(state.tone) document.getElementById("ui-tone").value = state.tone;
          if(state.goal) document.getElementById("ui-goal").value = state.goal;
          if(state.obj) document.getElementById("ui-objection").value = state.obj;
        } else {
           document.getElementById("ui-role").value = "Бизнес-консультант платформы SetHubble";
        }
        compilePrompt();
      }

      // =========================================================================
      // МАРКЕТИНГ: ЛОГИКА ССЫЛОК И QR
      // =========================================================================
      function getActiveLink() {
        if (currentLinkMode === 'offline') return b2bRefLink || (refLink + "&role=b2b");
        return refLink || `https://sethubble.ru/join/?page=${userData?.partner_id || "p_qdr"}`;
      }

      function setLinkMode(mode) {
        currentLinkMode = mode;
        const btnOn = document.getElementById('linkModeOnline');
        const btnOff = document.getElementById('linkModeOffline');
        
        if (mode === 'online') {
          btnOn.className = "flex-1 py-2 rounded-lg text-xs font-bold bg-cyan-600 text-white transition-all shadow-lg";
          btnOff.className = "flex-1 py-2 rounded-lg text-xs font-bold text-gray-400 hover:text-white hover:bg-white/5 transition-all";
        } else {
          btnOff.className = "flex-1 py-2 rounded-lg text-xs font-bold bg-purple-600 text-white transition-all shadow-lg";
          btnOn.className = "flex-1 py-2 rounded-lg text-xs font-bold text-gray-400 hover:text-white hover:bg-white/5 transition-all";
        }
        
        const activeUrl = getActiveLink();
        document.getElementById('botLinkDisplay').textContent = activeUrl;
        document.querySelectorAll('.bot-link').forEach(el => el.textContent = activeUrl);
        
        const qrContainer = document.getElementById("qrcode");
        qrContainer.innerHTML = "";
        new QRCode(qrContainer, { text: activeUrl, width: 180, height: 180, colorDark: "#000000", colorLight: "#ffffff", correctLevel: QRCode.CorrectLevel.H });
        
        if (tg?.HapticFeedback) tg.HapticFeedback.selectionChanged();
      }

      document.getElementById("copyLinkBtn").addEventListener("click", function() {
        navigator.clipboard.writeText(getActiveLink()).then(() => {
          const original = this.innerHTML;
          this.innerHTML = "<span>✅</span> СКОПИРОВАНО";
          this.classList.replace("bg-white/10", "bg-green-600");
          if(tg?.HapticFeedback) tg.HapticFeedback.notificationOccurred("success");
          setTimeout(() => { this.innerHTML = original; this.classList.replace("bg-green-600", "bg-white/10"); }, 2000);
        });
      });

      document.getElementById("openMySiteBtn").addEventListener("click", () => {
        const link = getActiveLink();
        if (tg?.openLink) tg.openLink(link); else window.open(link, "_blank");
      });

      document.getElementById("createPdfBtn").addEventListener("click", () => {
        const link = getActiveLink();
        window.open(`https://qr2pdf.vercel.app/?link=${encodeURIComponent(link)}`, "_blank");
      });

      document.getElementById("printTableTentBtn").addEventListener("click", () => {
        const canvas = document.getElementById("qrcode").querySelector("canvas");
        if (canvas) {
          const imgUrl = canvas.toDataURL("image/png");
          const printWindow = window.open("", "_blank");
          printWindow.document.write(`
            <!DOCTYPE html><html><head><title>SetHubble QR</title>
            <style>
              body { font-family: sans-serif; text-align: center; padding: 40px; }
              .box { border: 2px solid #000; border-radius: 20px; display: inline-block; padding: 40px; margin-top: 50px; }
              h1 { font-size: 32px; margin-bottom: 10px; text-transform: uppercase; }
              p { font-size: 18px; color: #555; margin-bottom: 30px; }
              img { width: 300px; height: 300px; }
            </style></head><body>
              <div class="box">
                <h1>ОТКРОЙТЕ КАМЕРУ</h1>
                <p>Отсканируйте код, чтобы получить ИИ-систему</p>
                <img src="${imgUrl}"/>
              </div>
            </body></html>
          `);
          printWindow.document.close();
          setTimeout(() => printWindow.print(), 500);
        }
      });

      // === ИИ-ГЕНЕРАТОР ПОСТОВ ===
      async function generateAIPost() {
        const topic = document.getElementById("aiPostTopic").value.trim();
        const btn = document.getElementById("generatePostBtn");
        const resBox = document.getElementById("aiPostResult");
        const resText = document.getElementById("aiPostText");
        
        if(!topic) return showToast("Введите тему или аудиторию", "error");
        
        btn.innerHTML = "⏳ Пишу...";
        btn.disabled = true;
        
        try {
          const aiPrompt = `Напиши короткий, сочный и вирусный пост для соцсетей (до 600 символов) для аудитории: ${topic}. Продаем идею пассивного дохода на IT-платформе SetHubble. В конце органично вставь этот призыв и ссылку: ${getActiveLink()}`;
          
          const response = await fetch(BACKEND_URL, {
            method: "POST", headers: authHeaders,
            body: JSON.stringify({ action: "web-chat", message: aiPrompt, partner_id: "p_qdr" }) // Шлем запрос системному боту
          });
          const data = await response.json();
          
          if(data.answer) {
            resText.innerHTML = data.answer.replace(/\n/g, "<br>");
            resBox.classList.remove("hidden");
          } else {
            showToast("Ошибка ИИ", "error");
          }
        } catch(e) {
          showToast("Ошибка сети", "error");
        } finally {
          btn.innerHTML = "Сгенерировать";
          btn.disabled = false;
        }
      }

      function copyText(elementId, btnElement) {
        const text = document.getElementById(elementId).innerText;
        navigator.clipboard.writeText(text).then(() => {
          const orig = btnElement.innerHTML;
          btnElement.innerHTML = "<span>✅</span>";
          btnElement.classList.replace("bg-white/10", "bg-green-600");
          setTimeout(() => { btnElement.innerHTML = orig; btnElement.classList.replace("bg-green-600", "bg-white/10"); }, 2000);
        });
      }

      // =========================================================================
      // ИНТЕЛЛЕКТ: КОНСТРУКТОР ХАРАКТЕРА И МОДЕЛИ
      // =========================================================================
      const MODELS = {
        polza:[
          { id: "deepseek/deepseek-v4-flash", name: "DeepSeek v4 Flash (~$0.14 / 1M)" },
          { id: "openai/gpt-4o-mini", name: "GPT-4o Mini (~$0.15 / 1M)" },
          { id: "anthropic/claude-3.5-sonnet", name: "Claude 3.5 Sonnet (~$3.00 / 1M)" },
          { id: "meta-llama/llama-3-70b-instruct", name: "Llama 3 70B (~$0.40 / 1M)" }
        ],
        openrouter:[
          { id: "openai/gpt-4o-mini", name: "GPT-4o Mini (~$0.15 / 1M)" },
          { id: "openai/gpt-4o", name: "GPT-4o (~$2.50 / 1M)" },
          { id: "anthropic/claude-3.5-sonnet", name: "Claude 3.5 Sonnet (~$3.00 / 1M)" }
        ]
      };

      function updateModelsList(preselected = null) {
        const provider = document.getElementById("ai-provider").value;
        const sel = document.getElementById("ai-model");
        sel.innerHTML = "";
        MODELS[provider].forEach(m => {
          const opt = document.createElement("option");
          opt.value = m.id; opt.textContent = m.name;
          sel.appendChild(opt);
        });
        if(preselected) sel.value = preselected;
      }

      function compilePrompt() {
        const role = document.getElementById("ui-role").value || "Консультант";
        const tone = document.getElementById("ui-tone").value;
        const goal = document.getElementById("ui-goal").value;
        const obj = document.getElementById("ui-objection").value;
        
        let finalPrompt = `Ты — ${role}. Общайся с клиентом в стиле: ${tone}. Твоя главная цель диалога: ${goal}.`;
        if (obj) finalPrompt += ` Если клиент говорит, что ему дорого или он подумает, реагируй так: ${obj}.`;
        
        document.getElementById("ai-prompt-hidden").value = finalPrompt;
      }

      function applyAiPreset(type) {
        if(type === 'shark') {
          document.getElementById("ui-role").value = "Волк с Уолл-Стрит в крипте";
          document.getElementById("ui-tone").value = "Уверенный, давит на выгоду";
          document.getElementById("ui-goal").value = "Продать PRO-статус";
          document.getElementById("ui-objection").value = "Смеяться над сомнениями, давить на упущенную выгоду (FOMO)";
        } else if(type === 'mentor') {
          document.getElementById("ui-role").value = "Опытный бизнес-наставник";
          document.getElementById("ui-tone").value = "Эмпатичный, задает вопросы";
          document.getElementById("ui-goal").value = "Убедить зарегистрироваться в системе";
          document.getElementById("ui-objection").value = "Понимать страхи, успокаивать цифрами и фактами";
        } else if(type === 'techie') {
          document.getElementById("ui-role").value = "Senior IT-Архитектор";
          document.getElementById("ui-tone").value = "Сухой, оперирует цифрами";
          document.getElementById("ui-goal").value = "Закрыть на личный созвон с менеджером";
          document.getElementById("ui-objection").value = "Игнорировать эмоции, выдавать сухую ROI математику";
        } else if(type === 'provocateur') {
          document.getElementById("ui-role").value = "Дерзкий провокатор";
          document.getElementById("ui-tone").value = "Ироничный, использует реверсивную психологию";
          document.getElementById("ui-goal").value = "Продать PRO-статус";
          document.getElementById("ui-objection").value = "Говорить: 'Возможно этот бизнес слишком сложен для тебя, лучше оставайся в найме'";
        }
        compilePrompt();
        showToast("Пресет загружен! Не забудьте сохранить.");
      }

      async function saveAiSettings() {
        const btn = document.getElementById("saveAiBtn");
        btn.disabled = true; btn.innerHTML = "⏳ СОХРАНЯЮ...";

        const payload = {
          custom_prompt: document.getElementById("ai-prompt-hidden").value,
          ai_provider: document.getElementById("ai-provider").value,
          ai_model: document.getElementById("ai-model").value,
          custom_api_key: document.getElementById("ai-api-key").value.trim(),
          user_daily_limit: parseInt(document.getElementById("ai-limit").value) || 0,
          ai_ui_state: {
            role: document.getElementById("ui-role").value,
            tone: document.getElementById("ui-tone").value,
            goal: document.getElementById("ui-goal").value,
            obj: document.getElementById("ui-objection").value
          }
        };

        try {
          const res = await fetch(`${BACKEND_URL}/?action=update_ai_settings`, {
            method: "POST", headers: authHeaders, body: JSON.stringify(payload)
          });
          const data = await res.json();
          if(data.success) { showToast("Интеллект обновлён!"); btn.innerHTML = "✅ ГОТОВО"; }
          else { showToast("Ошибка", "error"); btn.innerHTML = "❌ ОШИБКА"; }
        } catch(e) { showToast("Ошибка сети", "error"); btn.innerHTML = "❌ ОШИБКА"; }
        finally { setTimeout(() => { btn.disabled = false; btn.innerHTML = "💾 СОХРАНИТЬ ИНТЕЛЛЕКТ"; }, 2000); }
      }

      // === ТЕСТОВЫЙ ЧАТ ===
      async function sendTestMessage() {
        const inp = document.getElementById("testChatInput");
        const txt = inp.value.trim();
        if(!txt) return;
        
        inp.value = "";
        appendTestChat(txt, true);
        
        const btn = document.getElementById("testSendBtn");
        btn.disabled = true; btn.innerHTML = "⏳";

        try {
          // Отправляем запрос на web-chat endpoint, используя ВАШИ текущие настройки (бэкенд сам подхватит их из базы)
          const response = await fetch(BACKEND_URL, {
            method: "POST", headers: authHeaders,
            body: JSON.stringify({ action: "web-chat", message: txt, partner_id: userData.partner_id })
          });
          const data = await response.json();
          appendTestChat(data.answer || "Ошибка ИИ", false);
        } catch(e) {
          appendTestChat("Сетевая ошибка", false);
        } finally {
          btn.disabled = false; btn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"></path></svg>`;
        }
      }

      function appendTestChat(text, isUser) {
        const area = document.getElementById("testChatArea");
        const div = document.createElement("div");
        div.className = `p-3 text-sm rounded-2xl max-w-[85%] ${isUser ? "bg-cyan-600 text-white self-end rounded-br-sm" : "bg-gray-800/80 text-gray-200 self-start rounded-tl-sm"}`;
        div.innerHTML = text.replace(/\n/g, "<br>");
        area.appendChild(div);
        area.scrollTop = area.scrollHeight;
      }

      // Enter for test chat
      document.getElementById("testChatInput").addEventListener("keypress", (e) => {
        if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); sendTestMessage(); }
      });

      initUser();
    </script>
  </body>
</html>
