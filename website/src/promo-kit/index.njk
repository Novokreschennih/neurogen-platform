        function showToast(message, type = "success") {
            const container = document.getElementById("toast-container");
            const toast = document.createElement("div");
            const icons = { success: '✅', error: '❌', warning: '⚠️', info: 'ℹ️' };
            const colors = { success: 'border-green-500/30', error: 'border-red-500/30', warning: 'border-yellow-500/30', info: 'border-blue-500/30' };
            toast.className = `toast flex items-center gap-2 bg-black/95 backdrop-blur-lg border ${colors[type]} px-5 py-3 rounded-full text-sm font-medium shadow-2xl`;
            toast.innerHTML = `${icons[type]} ${message}`;
            container.appendChild(toast);
            requestAnimationFrame(() => toast.classList.add("show"));
            setTimeout(() => { toast.classList.remove("show"); setTimeout(() => toast.remove(), 300); }, 3000);
        }

        function switchTab(tab) {['marketing', 'ai', 'about'].forEach(t => {
            const content = document.getElementById(`content-${t}`);
