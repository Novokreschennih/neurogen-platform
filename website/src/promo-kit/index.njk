            animateValue("statClicks", 0, parseInt(userData.clicks) || 0, 1500);
            animateValue("statLeads", 0, parseInt(userData.referrals) || 0, 1500);
            animateValue("statEarnings", 0, parseFloat(userData.earnings) || 0, 1500, true);
            document.getElementById("header-earnings").textContent = `$${(parseFloat(userData.earnings) || 0).toFixed(2)}`;

