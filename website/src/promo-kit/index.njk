    <script>
        // INIT TELEGRAM WEBAPP
        let tg = null;
        try { tg = window.Telegram?.WebApp; if(tg) { tg.expand(); tg.ready(); } } catch(e) {}

        // GLOBAL STATE
        let userData = null;
        let refLink = "";
        let b2bRefLink = "";
        let currentLinkMode = "online";
        let authHeaders = { "Content-Type": "application/json" };
        let webAppJwt = ""; 
        let currentSessionId = localStorage.getItem("neurogen_web_session");

        const urlParamsAPI = new URLSearchParams(window.location.search);
        const BACKEND_URL = urlParamsAPI.get("api") || "https://d5dsbah1d4ju0glmp9d0.3zvepvee.apigw.yandexcloud.net";

        // TOASTS
        function showToast(message, type = "success") {
            const container = document.getElementById("toast-container");
            const toast = document.createElement("div");
            const icons = { success: '✅', error: '❌', warning: '⚠️', info: 'ℹ️' };
            const colors = { success: 'border-green-500/30', error: 'border-red-500/30', warning: 'border-yellow-500/30', info: 'border-blue-500/30' };
            
            toast.className = `toast flex items-center gap-2 bg-black/95 backdrop-blur-lg border ${colors[type]} px-5 py-3 rounded-full text-sm font-medium shadow-2xl`;
            toast.innerHTML = `${icons[type]} ${message}`;
            
            container.appendChild(toast);
            requestAnimationFrame(() => toast.classList.add("show"));
            setTimeout(() => { toast.classList.remove("show"); setTimeout(() => toast.remove(), 300); }, 3000);
        }

        // TABS
        function switchTab(tab) {['marketing', 'ai', 'about'].forEach(t => {
                const content = document.getElementById(`content-${t}`);
                const btn = document.getElementById(`tab-${t}`);
                if (content && btn) {
                    if (t === tab) {
                        content.classList.remove('hidden');
                        btn.classList.add('tab-active');
                        btn.classList.replace('text-gray-400', 'text-white');
                    } else {
                        content.classList.add('hidden');
                        btn.classList.remove('tab-active');
                        btn.classList.replace('text-white', 'text-gray-400');
                    }
                }
            });
            if(tg?.HapticFeedback) tg.HapticFeedback.impactOccurred("light");
        }

        // INIT USER
        async function initUser() {
            const urlParams = new URLSearchParams(window.location.search);
            const urlToken = urlParams.get("token");

            if (urlToken && urlToken !== "undefined" && urlToken !== "null") {
                authHeaders["Authorization"] = `Bearer ${urlToken}`;
                localStorage.setItem("neurogen_jwt", urlToken);
                webAppJwt = urlToken; 
                try {
                    const cleanParams = new URLSearchParams(window.location.search);
                    cleanParams.delete("token");
                    const newUrl = window.location.pathname + (cleanParams.toString() ? "?" + cleanParams.toString() : "");
                    window.history.replaceState({}, document.title, newUrl);
                } catch(e) {}
            } else if (localStorage.getItem("neurogen_jwt")) {
                webAppJwt = localStorage.getItem("neurogen_jwt");
                authHeaders["Authorization"] = `Bearer ${webAppJwt}`;
            } else if (tg?.initData) {
                authHeaders["x-telegram-initdata"] = tg.initData;
            } else {
                document.getElementById("loadingBlock").innerHTML = `<div class="text-red-400 text-sm font-bold">⚠️ ОШИБКА АВТОРИЗАЦИИ</div>`;
                return;
            }

            try {
                const response = await fetch(`${BACKEND_URL}/?action=get_partner_link`, {
                    method: "POST", headers: authHeaders, body: JSON.stringify({ action: "get_partner_link" })
                });
                if (!response.ok) throw new Error("Сессия истекла");
                
                const data = await response.json();
                if (data.success) {
                    userData = data.user;
                    refLink = data.refLink;
                    b2bRefLink = data.b2bRefLink || null;
                    initUI();
                } else throw new Error(data.error);
            } catch (error) {
                document.getElementById("loadingBlock").innerHTML = `<div class="text-red-400 text-sm font-bold">⚠️ ${error.message}</div>`;
            }
        }

        // ANIMATE NUMBERS
        function animateValue(id, start, end, duration, isCurrency = false) {
            const obj = document.getElementById(id);
            if(!obj) return;
            let startTimestamp = null;
            const step = (timestamp) => {
                if (!startTimestamp) startTimestamp = timestamp;
                const progress = Math.min((timestamp - startTimestamp) / duration, 1);
                const easeOutQuart = 1 - Math.pow(1 - progress, 4);
                const current = progress === 1 ? end : start + (end - start) * easeOutQuart;
                obj.innerHTML = isCurrency ? `$${current.toFixed(2)}` : Math.floor(current);
                if (progress < 1) window.requestAnimationFrame(step);
            };
            window.requestAnimationFrame(step);
        }

        // INIT UI
        function initUI() {
            document.getElementById("loadingBlock").classList.add("hidden");
            document.getElementById("mainContent").classList.remove("hidden");

            if (userData.first_name) {
                document.getElementById("userAvatar").textContent = userData.first_name[0].toUpperCase();
            }

            animateValue("statClicks", 0, parseInt(userData.clicks) || 0, 1500);
            animateValue("statLeads", 0, parseInt(userData.referrals) || 0, 1500);
            animateValue("statEarnings", 0, parseFloat(userData.earnings) || 0, 1500, true);
            document.getElementById("header-earnings").textContent = `$${(parseFloat(userData.earnings) || 0).toFixed(2)}`;

            const xp = parseInt(userData.xp) || 0;
            const price = xp >= 100 ? 20 : 40;
            const productId = xp >= 100 ? "103_97998" : "142_ee4e9";
            const inviterId = userData.inviter_sh_id || "1123";
            const paymentUrl = `https://hubblepay.net/${productId}?afid=${inviterId}`;
            
            const upgradeBtn = document.getElementById("btn-upgrade-pro");
            if(upgradeBtn) {
                upgradeBtn.href = paymentUrl;
                upgradeBtn.innerHTML = `💎 КУПИТЬ PRO ЗА $${price}`;
            }

            if (userData.is_pro) {
                document.getElementById("tariff-pro").classList.remove("hidden");
                document.getElementById("tariff-free").classList.add("hidden");
                document.getElementById("openCrmBtn").onclick = () => {
                    window.open(`https://novokreschennih.github.io/crm-dashboard/?token=${webAppJwt}`, "_blank");
                };
            }

            // Блокировка ссылки на материалы
            const materialsBtn = document.getElementById("businessMaterialsBtn");
            if(materialsBtn) {
                materialsBtn.onclick = (e) => {
                    // Разрешаем если PRO, или если есть сохраненный тег о прохождении (здесь условная проверка по xp, в идеале добавить в ответ API)
                    if(!userData.is_pro && xp < 90) {
                        e.preventDefault();
                        showToast("⚠️ Доступно после прохождения Модуля 3!", "warning");
                    } else {
                        window.open("https://disk.yandex.ru/d/a2Gsuwnu32eJKg", "_blank");
                    }
                };
            }

            setLinkMode('online');

            // AI Status
            const now = Date.now();
            const aiUntil = parseInt(userData.ai_active_until) || 0;
            const isAiActive = aiUntil > now;

            const sb = document.getElementById("ai-status-banner");
            const sTitle = document.getElementById("status-title");
            const sDate = document.getElementById("status-date");
            const sBadge = document.getElementById("status-badge");
            const sIcon = document.getElementById("status-icon");

            if (isAiActive) {
                document.getElementById("ai-constructor").classList.remove("hidden");
                document.getElementById("ai-paywall").classList.add("hidden");

                const daysLeft = Math.ceil((aiUntil - now) / 86400000);
                const fDate = new Date(aiUntil).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long' });

                if (daysLeft <= 3) {
                    sb.className = "mb-6 p-4 rounded-2xl border border-yellow-500/30 bg-yellow-500/5 flex items-center justify-between";
                    sTitle.textContent = "Пробный период (Trial)";
                    sTitle.className = "text-xs font-bold text-yellow-400 uppercase tracking-wider";
                    sDate.textContent = `Доступ закроется ${fDate}`;
                    sBadge.textContent = "3 ДНЯ БЕСПЛАТНО";
                    sBadge.className = "px-3 py-1 rounded-full text-[10px] font-black uppercase bg-yellow-500 text-black";
                    sIcon.textContent = "⏳";
                } else {
                    sb.className = "mb-6 p-4 rounded-2xl border border-cyan-500/30 bg-cyan-500/5 flex items-center justify-between";
                    sTitle.textContent = "Интеллект активен";
                    sTitle.className = "text-xs font-bold text-cyan-400 uppercase tracking-wider";
                    sDate.textContent = `Подписка активна до ${fDate}`;
                    sBadge.textContent = "PREMIUM";
                    sBadge.className = "px-3 py-1 rounded-full text-[10px] font-black uppercase bg-cyan-500 text-black";
                    sIcon.textContent = "🚀";
                }
            } else {
                document.getElementById("ai-constructor").classList.add("hidden");
                document.getElementById("ai-paywall").classList.remove("hidden");
            }

            if (userData.ai_provider) document.getElementById("ai-provider").value = userData.ai_provider;
            updateModelsList(userData.ai_model); 
            if (userData.user_daily_limit) document.getElementById("ai-limit").value = userData.user_daily_limit;
            if (userData.custom_api_key) document.getElementById("ai-api-key").value = userData.custom_api_key;
            
            if (userData.ai_ui_state) {
                const state = userData.ai_ui_state;
                if(state.role) document.getElementById("ui-role").value = state.role;
                if(state.tone) document.getElementById("ui-tone").value = state.tone;
                if(state.goal) document.getElementById("ui-goal").value = state.goal;
                if(state.obj) document.getElementById("ui-objection").value = state.obj;
            } else {
                document.getElementById("ui-role").value = "Бизнес-консультант платформы SetHubble";
            }
            compilePrompt();
        }

        // LINKS & MODES
        function getActiveLink() {
            if (currentLinkMode === 'offline') return b2bRefLink || (refLink + "&role=b2b");
            return refLink || `https://sethubble.ru/join/?page=${userData?.partner_id || "p_qdr"}`;
        }

        function setLinkMode(mode) {
            currentLinkMode = mode;
            const btnOn = document.getElementById('linkModeOnline');
            const btnOff = document.getElementById('linkModeOffline');
            
            if (mode === 'online') {
                btnOn.className = "btn flex-1 py-2.5 rounded-lg text-xs font-bold bg-gradient-to-r from-cyan-500 to-blue-500 text-white shadow-lg";
                btnOff.className = "btn flex-1 py-2.5 rounded-lg text-xs font-bold text-gray-400 hover:text-white transition-all";
            } else {
                btnOff.className = "btn flex-1 py-2.5 rounded-lg text-xs font-bold bg-gradient-to-r from-purple-500 to-pink-500 text-white shadow-lg";
                btnOn.className = "btn flex-1 py-2.5 rounded-lg text-xs font-bold text-gray-400 hover:text-white transition-all";
            }
            
            const activeUrl = getActiveLink();
            document.getElementById('botLinkDisplay').textContent = activeUrl;
            document.querySelectorAll('.bot-link').forEach(el => el.textContent = activeUrl);
            
            const qrContainer = document.getElementById("qrcode");
            qrContainer.innerHTML = "";
            new QRCode(qrContainer, { text: activeUrl, width: 180, height: 180, colorDark: "#000000", colorLight: "#ffffff", correctLevel: QRCode.CorrectLevel.H });
            
            if (tg?.HapticFeedback) tg.HapticFeedback.selectionChanged();
        }

        function copyToClipboard(text, isElement = true) {
            const content = isElement ? document.getElementById(text).innerText : text;
            navigator.clipboard.writeText(content).then(() => {
                showToast("Скопировано!", "success");
                if(tg?.HapticFeedback) tg.HapticFeedback.notificationOccurred("success");
            });
        }

        document.getElementById("copyLinkBtn").addEventListener("click", () => copyToClipboard(getActiveLink(), false));
        document.getElementById("openMySiteBtn").addEventListener("click", () => {
            const link = getActiveLink();
            if (tg?.openLink) tg.openLink(link); else window.open(link, "_blank");
        });
        document.getElementById("createPdfBtn").addEventListener("click", () => {
            window.open(`https://qr2pdf.vercel.app/?link=${encodeURIComponent(getActiveLink())}`, "_blank");
        });

        // PRINT FLYER (Рекламный B2B-Флаер на 1 страницу)
        document.getElementById("printTableTentBtn").addEventListener("click", () => {
            const canvas = document.getElementById("qrcode").querySelector("canvas");
            if (canvas) {
                const imgUrl = canvas.toDataURL("image/png");
                const printWindow = window.open("", "_blank");
                printWindow.document.write(`
                    <!DOCTYPE html><html><head><title>Рекламный Флаер B2B</title>
                    <style>
                        @page { size: A4 portrait; margin: 0; }
                        body {
                            font-family: 'Segoe UI', Arial, sans-serif; text-align: center; color: #111;
                            margin: 0; padding: 20px; background: #fff; box-sizing: border-box; height: 100vh;
                        }
                        .container {
                            max-width: 800px; height: 96%; margin: 0 auto; border: 4px solid #eee;
                            padding: 30px 40px; border-radius: 30px; display: flex; flex-direction: column;
                            justify-content: space-between; box-sizing: border-box;
                        }
                        .header-sec { margin-bottom: 10px; }
                        .tag {
                            display: inline-block; background: #06b6d4; color: #fff; padding: 6px 18px;
                            border-radius: 20px; font-weight: bold; font-size: 14px; text-transform: uppercase;
                            margin-bottom: 15px; letter-spacing: 1px;
                        }
                        h1 { font-size: 32px; text-transform: uppercase; margin-bottom: 10px; font-weight: 900; line-height: 1.2; color: #000; }
                        p.subtitle { font-size: 16px; color: #555; margin-bottom: 0; line-height: 1.5; padding: 0 20px; }
                        
                        /* Выстраиваем карточки в 2 колонки для экономии места */
                        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; text-align: left; margin-bottom: 10px; }
                        .card { border-left: 4px solid #06b6d4; padding: 15px 20px; background: #fafafa; border-radius: 0 15px 15px 0; }
                        .card.neuro { border-left-color: #a855f7; background: #fdfafb; }
                        .card h3 { margin: 0 0 8px 0; font-size: 16px; font-weight: 800; color: #000; }
                        .card p { margin: 0; font-size: 13px; color: #444; line-height: 1.5; }
                        
                        .qr-sec { text-align: center; margin-top: auto; }
                        .qr-sec h3 { margin-bottom: 15px; font-size: 20px; color: #000; font-weight: 800; }
                        .qr-box { margin: 0 auto; padding: 15px; border: 4px dashed #ccc; display: inline-block; border-radius: 30px; background: #fff; }
                    </style></head><body>
                        <div class="container">
                            <div class="header-sec">
                                <div class="tag">САРАФАННОЕ РАДИО 2.0</div>
                                <h1>КАК ПРИВЛЕКАТЬ КЛИЕНТОВ<br>БЕЗ ЗАТРАТ НА РЕКЛАМУ?</h1>
                                <p class="subtitle">Кардинально новый подход к маркетингу для офлайн-бизнеса.<br>Вы платите только за реальный результат.</p>
                            </div>
                            
                            <div class="grid">
                                <div class="card">
                                    <h3>1. Сеть мотивированных партнеров</h3>
                                    <p>Предоставьте клиентам скидку, а тем, кто их привел — агентское вознаграждение. Это формирует сеть агентов, которые сами рекламируют ваши услуги. Вы платите комиссию только за реальные деньги в кассе.</p>
                                </div>
                                <div class="card">
                                    <h3>2. Простое внедрение</h3>
                                    <p>Вам не нужно менять прием платежей или структуру бизнеса. Вы принимаете наличные и карты как обычно, а кассир лишь фиксирует промокод покупателя в экосистеме SetHubble.</p>
                                </div>
                                <div class="card">
                                    <h3>3. IT-инструменты в подарок</h3>
                                    <p>Платформа бесплатно создаст сайты-визитки для вашего бизнеса и ваших агентов. Эффект вирусного распространения и рекомендаций запускается мгновенно.</p>
                                </div>
                                <div class="card neuro">
                                    <h3>4. Ваш ИИ-ассистент NeuroGen</h3>
                                    <p>Система включает умного чат-бота (Telegram/VK). Он общается с аудиторией 24/7, автоматически расширяет вашу сеть партнеров и генерирует для вас дополнительный пассивный доход.</p>
                                </div>
                            </div>
                            
                            <div class="qr-sec">
                                <h3>Отсканируйте код для бесплатного запуска:</h3>
                                <div class="qr-box"><img src="${imgUrl}" style="width:200px;height:200px;"/></div>
                            </div>
                        </div>
                    </body></html>
                `);
                printWindow.document.close();
                // Небольшая задержка перед вызовом диалога печати для загрузки картинки
                setTimeout(() => printWindow.print(), 800);
            }
        });

        // AI POST GENERATOR (Изолированный маршрут generate-post)
        async function generateAIPost() {
            const select = document.getElementById("aiPostTopic");
            const topic = select.options[select.selectedIndex]?.text;
            const btn = document.getElementById("generatePostBtn");
            const resBox = document.getElementById("aiPostResult");
            const resText = document.getElementById("aiPostText");
            
            if(!select.value) return showToast("Выберите аудиторию!", "warning");
            
            btn.disabled = true;
            const original = btn.innerHTML;
            btn.innerHTML = "⏳ Пишу...";
            
            try {
                const response = await fetch(BACKEND_URL, {
                    method: "POST", headers: authHeaders,
                    body: JSON.stringify({
                        action: "generate-post",
                        topic: topic,
                        link: getActiveLink(),
                        sessionId: currentSessionId
                    })
                });
                const data = await response.json();
                
                if(data.answer) {
                    resText.innerHTML = data.answer.replace(/\n/g, "<br>");
                    resBox.classList.remove("hidden");
                    resBox.classList.add("animate-fadeInUp");
                    
                    if (data.answer.includes("⏳")) {
                        showToast("Достигнут лимит генераций", "warning");
                    } else {
                        showToast("Пост готов!", "success");
                    }
                }
            } catch(e) {
                showToast("Ошибка связи с сервером", "error");
            } finally {
                btn.innerHTML = original;
                btn.disabled = false;
            }
        }

        // AI CONSTRUCTOR
        const MODELS = {
            polza:[
                { id: "deepseek/deepseek-v4-flash", name: "DeepSeek v4 Flash (~$0.14 / 1M)" },
                { id: "openai/gpt-4o-mini", name: "GPT-4o Mini (~$0.15 / 1M)" },
                { id: "anthropic/claude-3.5-sonnet", name: "Claude 3.5 Sonnet (~$3.00 / 1M)" },
                { id: "meta-llama/llama-3-70b-instruct", name: "Llama 3 70B (~$0.40 / 1M)" }
            ],
            openrouter:[
                { id: "openai/gpt-4o-mini", name: "GPT-4o Mini (~$0.15 / 1M)" },
                { id: "openai/gpt-4o", name: "GPT-4o (~$2.50 / 1M)" },
                { id: "anthropic/claude-3.5-sonnet", name: "Claude 3.5 Sonnet (~$3.00 / 1M)" }
            ]
        };

        function updateModelsList(preselected = null) {
            const provider = document.getElementById("ai-provider").value;
            const sel = document.getElementById("ai-model");
            sel.innerHTML = "";
            MODELS[provider].forEach(m => {
                const opt = document.createElement("option");
                opt.value = m.id; opt.textContent = m.name;
                sel.appendChild(opt);
            });
            if(preselected) sel.value = preselected;
        }

        function compilePrompt() {
            const role = document.getElementById("ui-role").value || "Консультант";
            const tone = document.getElementById("ui-tone").value;
            const goal = document.getElementById("ui-goal").value;
            const obj = document.getElementById("ui-objection").value;
            
            let finalPrompt = `Ты — ${role}. Общайся с клиентом в стиле: ${tone}. Твоя главная цель диалога: ${goal}.`;
            if (obj) finalPrompt += ` Если клиент говорит, что ему дорого или он подумает, реагируй так: ${obj}.`;
            document.getElementById("ai-prompt-hidden").value = finalPrompt;
        }

        function applyAiPreset(type) {
            const presets = {
                shark:["Волк с Уолл-Стрит в крипте", "Уверенный, давит на выгоду", "Продать PRO-статус", "Смеяться над сомнениями, давить на упущенную выгоду (FOMO)"],
                mentor:["Опытный бизнес-наставник", "Эмпатичный, задает вопросы", "Убедить зарегистрироваться в системе", "Понимать страхи, успокаивать цифрами и фактами"],
                techie:["Senior IT-Архитектор", "Сухой, оперирует цифрами", "Закрыть на личный созвон с менеджером", "Игнорировать эмоции, выдавать сухую ROI математику"],
                friend:["Заботливый друг", "Эмпатичный, задает вопросы", "Убедить зарегистрироваться в системе", "Мягко отпускать, давать интригу и предлагать помощь"]
            };
            const p = presets[type];
            document.getElementById("ui-role").value = p[0];
            document.getElementById("ui-tone").value = p[1];
            document.getElementById("ui-goal").value = p[2];
            document.getElementById("ui-objection").value = p[3];
            compilePrompt();
            showToast("Пресет загружен! Не забудьте сохранить.", "success");
        }

        async function saveAiSettings() {
            const btn = document.getElementById("saveAiBtn");
            btn.disabled = true; const original = btn.innerHTML; btn.innerHTML = "⏳ СОХРАНЯЮ...";

            const payload = {
                custom_prompt: document.getElementById("ai-prompt-hidden").value,
                ai_provider: document.getElementById("ai-provider").value,
                ai_model: document.getElementById("ai-model").value,
                custom_api_key: document.getElementById("ai-api-key").value.trim(),
                user_daily_limit: parseInt(document.getElementById("ai-limit").value) || 0,
                ai_ui_state: {
                    role: document.getElementById("ui-role").value,
                    tone: document.getElementById("ui-tone").value,
                    goal: document.getElementById("ui-goal").value,
                    obj: document.getElementById("ui-objection").value
                }
            };

            try {
                const res = await fetch(`${BACKEND_URL}/?action=update_ai_settings`, {
                    method: "POST", headers: authHeaders, body: JSON.stringify(payload)
                });
                const data = await res.json();
                if(data.success) { showToast("Интеллект обновлён!", "success"); }
                else { showToast("Ошибка сохранения", "error"); }
            } catch(e) { showToast("Ошибка сети", "error"); }
            finally { btn.disabled = false; btn.innerHTML = original; }
        }

        // TEST CHAT
        async function sendTestMessage() {
            const inp = document.getElementById("testChatInput");
            const txt = inp.value.trim();
            if(!txt) return;
            
            inp.value = "";
            appendTestChat(txt, true);
            
            const area = document.getElementById("testChatArea");
            const typingId = "typing-" + Date.now();
            area.insertAdjacentHTML('beforeend', `<div id="${typingId}" class="p-3 text-sm rounded-2xl max-w-[85%] bg-gray-800/80 text-gray-200 self-start shadow-md"><div class="typing-indicator"><span></span><span></span><span></span></div></div>`);
            area.scrollTop = area.scrollHeight;

            const btn = document.getElementById("testSendBtn");
            btn.disabled = true;

            try {
                const response = await fetch(BACKEND_URL, {
                    method: "POST", headers: authHeaders,
                    body: JSON.stringify({ action: "web-chat", message: txt, partner_id: userData.partner_id, sessionId: currentSessionId })
                });
                const data = await response.json();
                document.getElementById(typingId)?.remove();
                appendTestChat(data.answer || "Ошибка ИИ", false);
            } catch(e) {
                document.getElementById(typingId)?.remove();
                appendTestChat("Сетевая ошибка", false);
            } finally {
                btn.disabled = false;
            }
        }

        function appendTestChat(text, isUser) {
            const area = document.getElementById("testChatArea");
            const div = document.createElement("div");
            div.className = `chat-msg p-4 text-sm rounded-2xl max-w-[85%] shadow-md ${isUser ? "bg-gradient-to-r from-cyan-600 to-blue-600 text-white self-end rounded-br-2xl rounded-tr-2xl rounded-tl-2xl" : "bg-gray-800/80 text-gray-200 self-start rounded-bl-2xl rounded-tr-2xl rounded-br-2xl"}`;
            div.innerHTML = text.replace(/\n/g, "<br>");
            area.appendChild(div);
            area.scrollTop = area.scrollHeight;
        }

        document.getElementById("testChatInput").addEventListener("keypress", (e) => {
            if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); sendTestMessage(); }
        });

        window.addEventListener('DOMContentLoaded', () => { initUser(); });
    </script>
</body>
</html>