              </div>
              <p class="text-sm text-gray-400">
                Закрыть страницу. Продолжить сжигать рекламные бюджеты. Терять
                клиентов. Работать 24/7 и смотреть, как нейросети забирают твою
                профессию.
              </p>
            </div>
            <div class="p-6 rounded-2xl bg-black/40 border border-gray-800 hover:border-cyan-500/50 transition-colors">
              <div class="text-cyan-400 font-bold mb-3 text-lg flex items-center gap-2">
                <span>🔵</span> СИНЯЯ ТАБЛЕТКА
              </div>
              <p class="text-sm text-gray-400">
                Нажать кнопку ниже. Потратить 60 секунд на запуск своего
                ИИ-клона. Оцифровать свою сеть, автоматизировать дожимы и
                забирать прибыль со всего рынка.
              </p>
            </div>
          </div>

          <div
            class="js-open-modal cursor-pointer relative inline-flex group mb-6 w-full md:w-auto"
            role="button"
            tabindex="0"
          >
            <div class="absolute transition-all duration-1000 opacity-70 -inset-px bg-gradient-to-r from-[#44BCFF] via-[#A855F7] to-[#06B6D4] rounded-xl blur-lg group-hover:opacity-100 group-hover:-inset-1 group-hover:duration-200">
            </div>
            <div class="relative w-full md:w-auto inline-flex items-center justify-center px-10 py-5 text-xl font-bold text-white transition-all duration-200 bg-gray-900 rounded-xl gap-3">
              <span>🚀 АКТИВИРОВАТЬ НЕЙРОСЕТЬ</span>
            </div>
          </div>

          <p class="text-sm text-gray-500 italic mt-4">
            Создание бота абсолютно бесплатно. Ты ничем не рискуешь.
          </p>
        </div>
      </section>
    </main>

    <!-- МОДАЛЬНОЕ ОКНО: Email + Выбор (Web / Telegram) -->
    <div
      id="leadModal"
      class="hidden fixed inset-0 z-50 flex items-center justify-center px-4 bg-black/80 backdrop-blur-sm transition-opacity duration-300 opacity-0"
    >
      <div
        id="modalContent"
        class="modal-enter w-full max-w-md bg-[#0a0a0a] border border-white/10 rounded-3xl p-6 relative shadow-2xl"
      >
        <button
          id="closeModal"
          class="absolute top-4 right-4 text-gray-500 hover:text-white transition-colors"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"
            >
            </path>
          </svg>
        </button>

        <!-- ШАГ 1: Сбор Email -->
        <div id="stepEmail" class="block">
          <div class="text-center mb-6">
            <div class="w-16 h-16 bg-gradient-to-br from-cyan-500 to-purple-600 rounded-full flex items-center justify-center text-2xl mx-auto mb-4 shadow-lg shadow-purple-500/20">
              📧
            </div>
            <h3 class="text-2xl font-bold text-white mb-2">
              Куда отправить доступы?
            </h3>
            <p class="text-sm text-gray-400">
              Мы пришлем резервную ссылку на твою систему и обучающие материалы.
            </p>
          </div>

          <form id="emailForm" class="space-y-4">
            <div>
              <input
                type="email"
                id="userEmail"
                required
                placeholder="твой@email.com"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition-all text-center text-lg"
              >
            </div>
            <button
              type="submit"
              id="submitEmailBtn"
              class="w-full bg-gradient-to-r from-cyan-500 to-purple-500 text-white font-bold py-3.5 rounded-xl hover:opacity-90 transition-opacity flex justify-center items-center gap-2"
            >
              ПРОДОЛЖИТЬ
            </button>
            <p id="emailError" class="text-red-400 text-xs text-center hidden">
              Пожалуйста, введи корректный email
            </p>
          </form>
          <p class="text-[10px] text-gray-500 text-center mt-4">
            Нажимая кнопку, ты соглашаешься с политикой конфиденциальности.
          </p>
        </div>

        <!-- ШАГ 2: Выбор платформы -->
        <div id="stepChoice" class="hidden">
          <div class="text-center mb-6">
            <div class="w-16 h-16 bg-gradient-to-br from-green-400 to-blue-500 rounded-full flex items-center justify-center text-2xl mx-auto mb-4 shadow-lg shadow-blue-500/20">
              ✅
            </div>
            <h3 class="text-2xl font-bold text-white mb-2">Отлично!</h3>
            <p class="text-sm text-gray-400">
              Где тебе удобнее пройти настройку?
            </p>
          </div>

          <div class="space-y-3">
            <button
              id="btnTelegram"
              class="w-full relative group overflow-hidden bg-[#2AABEE]/10 border border-[#2AABEE]/30 hover:border-[#2AABEE] rounded-xl p-4 text-left transition-all flex items-center gap-4"
            >
              <div class="text-3xl">✈️</div>
              <div>
                <div class="font-bold text-white group-hover:text-[#2AABEE] transition-colors">
                  Через Telegram-бота
                </div>
                <div class="text-xs text-gray-400">
                  Быстро, удобно, всё в мессенджере
                </div>
              </div>
            </button>

            <button
              id="btnVK"
              class="w-full relative group overflow-hidden bg-[#0077FF]/10 border border-[#0077FF]/30 hover:border-[#0077FF] rounded-xl p-4 text-left transition-all flex items-center gap-4"
            >
              <div class="text-3xl">💬</div>
              <div>
                <div class="font-bold text-white group-hover:text-[#0077FF] transition-colors">
                  Через ВКонтакте
                </div>
                <div class="text-xs text-gray-400">
                  Не заблокирован, аудитория 80M+ в РФ
                </div>
              </div>
            </button>

            <button
              id="btnWeb"
              class="w-full relative group overflow-hidden bg-white/5 border border-white/10 hover:border-cyan-500/50 rounded-xl p-4 text-left transition-all flex items-center gap-4"
            >
              <div class="text-3xl">🌐</div>
              <div>
                <div class="font-bold text-white group-hover:text-cyan-400 transition-colors">
                  Через Web-сайт
                </div>
                <div class="text-xs text-gray-400">
                  Работает в любом браузере, без VPN
                </div>
              </div>
            </button>

            <button
              id="btnEmail"
              class="w-full relative group overflow-hidden bg-white/5 border border-white/10 hover:border-green-500/50 rounded-xl p-4 text-left transition-all flex items-center gap-4"
            >
              <div class="text-3xl">📧</div>
              <div>
                <div class="font-bold text-white group-hover:text-green-400 transition-colors">
                  Email-рассылка
                </div>
                <div class="text-xs text-gray-400">
                  Пошаговая настройка через email
                </div>
              </div>
            </button>
          </div>
        </div>
      </div>
    </div>

    <footer class="w-full max-w-5xl mx-auto py-8 text-center text-gray-600 text-xs border-t border-gray-800/50">
      <div class="mb-4">
        SETHUBBLE © 2026 | Платформа партнерских программ и SaaS-экосистема
        нового поколения
      </div>
      <div class="flex justify-center gap-6">
        <a
          href="https://t.me/sethubble_support"
          class="hover:text-cyan-400 transition-colors"
        >Поддержка (Support)</a>
        <a href="#" class="hover:text-cyan-400 transition-colors"
        >Публичная оферта</a>
      </div>
    </footer>

    <script>
    document.addEventListener("DOMContentLoaded", () => {
  // === НАСТРОЙКИ ===
  const DEFAULT_BOT = "sethubble_biz_bot";
  const DEFAULT_PARTNER_ID = "p_qdr";

  // ⚠️ ЗАМЕНИ на реальный URL твоего API Gateway из Яндекса! ⚠️
  const API_URL =
    "https://d5dsbah1d4ju0glmp9d0.3zvepvee.apigw.yandexcloud.net/?action=web-chat";
  const WEB_CHAT_URL = "/ai/";
  // Прямая ссылка на диалог VK для корректной передачи ref
  const VK_COMMUNITY_URL = "https://vk.me/club237421168";

  // === ПЕРЕМЕННЫЕ ===
  let partnerId = null;
  let refBot = null;

  // === СТАБИЛЬНЫЙ SESSION ID ДЛЯ WEB-КАНАЛА ===
  let currentSessionId = localStorage.getItem("neurogen_web_session");
  if (!currentSessionId) {
    currentSessionId = `web_${
      Math.random().toString(36).substring(2, 15)
    }_${Date.now()}`;
    localStorage.setItem("neurogen_web_session", currentSessionId);
  }

  // === ИНИЦИАЛИЗАЦИЯ РЕФЕРАЛА (МУЛЬТИКАНАЛ v5.0) ===
  const urlParams = new URLSearchParams(window.location.search);
  let encodedId = urlParams.get("page");

  const fromHex = (hex) => {
    try {
      if (!/^[0-9a-fA-F]+$/.test(hex)) return null;
      if (hex.length % 2 !== 0) return null;
      let str = "";
      for (let i = 0; i < hex.length; i += 2) {
        str += String.fromCharCode(parseInt(hex.substr(i, 2), 16));
      }
      return str;
    } catch (e) {
      return null;
    }
  };

  if (encodedId) {
    const decoded = fromHex(encodedId);
    partnerId = (decoded && decoded.length > 1)
      ? decoded.trim()
      : encodedId.trim();
    if (partnerId) localStorage.setItem("neurogen_partner_id", partnerId);
  }

  if (!partnerId) {
    partnerId = localStorage.getItem("neurogen_partner_id")
      || DEFAULT_PARTNER_ID;
  }

  const storedBot = localStorage.getItem("neurogen_partner_bot");
  refBot = (storedBot && storedBot !== "sethubble_bot")
    ? storedBot
    : DEFAULT_BOT;

  const badge = document.getElementById("partner-badge");
  const nameEl = document.getElementById("partner-name");
  if (badge && nameEl && partnerId !== DEFAULT_PARTNER_ID) {
    nameEl.textContent = partnerId;
    badge.classList.remove("hidden");
  }

  // === ЛОГИКА МОДАЛЬНОГО ОКНА ===
  const modal = document.getElementById("leadModal");
  const modalContent = document.getElementById("modalContent");
  const btnOpenList = document.querySelectorAll(".js-open-modal");
  const btnClose = document.getElementById("closeModal");

  const stepEmail = document.getElementById("stepEmail");
  const stepChoice = document.getElementById("stepChoice");
  const emailForm = document.getElementById("emailForm");
  const emailInput = document.getElementById("userEmail");
  const emailError = document.getElementById("emailError");
  const submitEmailBtn = document.getElementById("submitEmailBtn");

  const btnWeb = document.getElementById("btnWeb");
  const btnTelegram = document.getElementById("btnTelegram");
  const btnVK = document.getElementById("btnVK");
  const btnEmail = document.getElementById("btnEmail");

  function openModal() {
    modal.classList.remove("hidden");
    setTimeout(() => {
      modal.classList.remove("opacity-0");
      modalContent.classList.add("modal-enter-active");
    }, 10);
    emailInput.focus();
  }

  function closeModal() {
    modal.classList.add("opacity-0");
    modalContent.classList.remove("modal-enter-active");
    setTimeout(() => {
      modal.classList.add("hidden");
    }, 300);
  }

  btnOpenList.forEach(btn => btn.addEventListener("click", openModal));
  btnClose.addEventListener("click", closeModal);
  modal.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  // === ОБРАБОТКА EMAIL ===
  emailForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    if (!emailRegex.test(email)) {
      emailError.classList.remove("hidden");
      return;
    }

    emailError.classList.add("hidden");
    submitEmailBtn.innerHTML =
      "<span class=\"animate-pulse\">ОТПРАВКА...</span>";
    submitEmailBtn.disabled = true;

    try {
      await fetch(API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          isEmail: true,
          email: email,
          partner_id: partnerId,
          sessionId: currentSessionId, // ТЕПЕРЬ ПЕРЕДАЕМ ID СЕССИИ ДЛЯ МЕРДЖА!
        }),
      });
      // Сохраняем в память для автоматического узнавания на /ai/
      localStorage.setItem("neurogen_email", email);
      localStorage.setItem("neurogen_email_submitted", "true");
    } catch (err) {
      console.log("API error, but proceeding local storage save.");
    }

    stepEmail.classList.add("hidden");
    stepChoice.classList.remove("hidden");
  });

  // === МАРШРУТИЗАЦИЯ ПО КАНАЛАМ (v6.0) ===

  function encodeEmailForUrl(email) {
    if (!email) return "";
    return btoa(email).replace(/\+/g, "-").replace(/\//g, "_").replace(
      /=/g,
      "",
    );
  }

  btnTelegram.addEventListener("click", () => {
    const email = emailInput.value.trim();
    const startPayload = email
      ? `${partnerId}-${encodeEmailForUrl(email)}`
      : partnerId;
    window.location.href = `https://t.me/${refBot}?start=${startPayload}`;
  });

  btnVK.addEventListener("click", () => {
    const email = emailInput.value.trim();
    const startPayload = email
      ? `${partnerId}-${encodeEmailForUrl(email)}`
      : partnerId;
    window.location.href = `${VK_COMMUNITY_URL}?ref=${startPayload}`;
  });

  btnWeb.addEventListener("click", () => {
    window.location.href = `${WEB_CHAT_URL}?ref=${partnerId}`;
  });

  btnEmail.addEventListener("click", () => {
    const email = emailInput.value.trim();
    stepChoice.innerHTML = `
      <div class="text-center">
        <div class="w-16 h-16 bg-gradient-to-br from-green-400 to-emerald-500 rounded-full flex items-center justify-center text-2xl mx-auto mb-4 shadow-lg shadow-green-500/20">📧</div>
        <h3 class="text-2xl font-bold text-white mb-2">Письмо уже в пути!</h3>
        <p class="text-sm text-gray-400 mb-4">Мы отправим пошаговую инструкцию на <b>${
      email || "твой email"
    }</b>.</p>
      </div>`;
  });
});
    </script>
  </body>
</html>
