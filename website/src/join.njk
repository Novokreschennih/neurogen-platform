              <input type="email" id="userEmail" required placeholder="твой@email.com" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition-all text-center text-lg">
            </div>
            <button type="submit" id="submitEmailBtn" class="w-full bg-gradient-to-r from-cyan-500 to-purple-500 text-white font-bold py-3.5 rounded-xl hover:opacity-90 transition-opacity flex justify-center items-center gap-2">
              ПРОДОЛЖИТЬ
            </button>
            <p id="emailError" class="text-red-400 text-xs text-center hidden">Пожалуйста, введи корректный email</p>
          </form>
          <p class="text-[10px] text-gray-500 text-center mt-4">Нажимая кнопку, ты соглашаешься с политикой конфиденциальности.</p>
        </div>

        <!-- ШАГ 2: Выбор платформы -->
        <div id="stepChoice" class="hidden">
          <div class="text-center mb-6">
            <div class="w-16 h-16 bg-gradient-to-br from-green-400 to-blue-500 rounded-full flex items-center justify-center text-2xl mx-auto mb-4 shadow-lg shadow-blue-500/20">✅</div>
            <h3 class="text-2xl font-bold text-white mb-2">Отлично!</h3>
            <p class="text-sm text-gray-400">Где тебе удобнее пройти настройку?</p>
          </div>

          <div class="space-y-3">
            <button id="btnTelegram" class="w-full relative group overflow-hidden bg-[#2AABEE]/10 border border-[#2AABEE]/30 hover:border-[#2AABEE] rounded-xl p-4 text-left transition-all flex items-center gap-4">
              <div class="text-3xl">✈️</div>
              <div>
                <div class="font-bold text-white group-hover:text-[#2AABEE] transition-colors">Через Telegram-бота</div>
                <div class="text-xs text-gray-400">Быстро, удобно, всё в мессенджере</div>
              </div>
            </button>

            <button id="btnVK" class="w-full relative group overflow-hidden bg-[#0077FF]/10 border border-[#0077FF]/30 hover:border-[#0077FF] rounded-xl p-4 text-left transition-all flex items-center gap-4">
              <div class="text-3xl">💬</div>
              <div>
                <div class="font-bold text-white group-hover:text-[#0077FF] transition-colors">Через ВКонтакте</div>
                <div class="text-xs text-gray-400">Не заблокирован, аудитория 80M+ в РФ</div>
              </div>
            </button>

            <button id="btnWeb" class="w-full relative group overflow-hidden bg-white/5 border border-white/10 hover:border-cyan-500/50 rounded-xl p-4 text-left transition-all flex items-center gap-4">
              <div class="text-3xl">🌐</div>
              <div>
                <div class="font-bold text-white group-hover:text-cyan-400 transition-colors">Через Web-сайт</div>
                <div class="text-xs text-gray-400">Работает в любом браузере, без VPN</div>
              </div>
            </button>

            <button id="btnEmail" class="w-full relative group overflow-hidden bg-white/5 border border-white/10 hover:border-green-500/50 rounded-xl p-4 text-left transition-all flex items-center gap-4">
              <div class="text-3xl">📧</div>
              <div>
                <div class="font-bold text-white group-hover:text-green-400 transition-colors">Email-рассылка</div>
                <div class="text-xs text-gray-400">Пошаговая настройка через email</div>
              </div>
            </button>
          </div>
        </div>

        <!-- ШАГ 3: Email отправлен -->
        <div id="email-submitted" class="hidden">
          <div class="text-center mb-6">
            <div class="w-16 h-16 bg-gradient-to-br from-green-400 to-emerald-500 rounded-full flex items-center justify-center text-2xl mx-auto mb-4 shadow-lg shadow-green-500/20">✉️</div>
            <h3 class="text-2xl font-bold text-white mb-2">Проверь свою почту!</h3>
            <p class="text-sm text-gray-400 mb-2">Мы отправили ссылку для подтверждения на:</p>
            <p id="email-submitted-msg" class="text-lg font-bold text-green-400 mb-4"></p>
            <p class="text-xs text-gray-500">Перейди по ссылке в письме, чтобы подтвердить email и продолжить настройку.</p>
          </div>
        </div>

        <!-- ШАГ 4: С возвращением! -->
        <div id="stepRemembered" class="hidden">
          <div class="text-center mb-6">
            <div class="w-20 h-20 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-3xl mx-auto mb-4 shadow-lg shadow-purple-500/20 animate-bounce">👋</div>
            <h3 class="text-2xl font-bold text-white mb-2">С возвращением!</h3>
            <p class="text-sm text-gray-400 mb-2">Я вспомнил тебя</p>
            <p id="remembered-email-msg" class="text-lg font-semibold text-purple-400 mb-6"></p>
            <button id="btnProceedToChannels" class="w-full bg-gradient-to-r from-cyan-500 to-purple-500 text-white font-bold py-3.5 rounded-xl hover:opacity-90 transition-opacity flex justify-center items-center gap-2">
              Выбрать канал для настройки →
            </button>
          </div>
        </div>

      </div>
    </div>

    <footer class="w-full max-w-5xl mx-auto py-8 text-center text-gray-600 text-xs border-t border-gray-800/50 mt-10">
      <div class="mb-4">NEUROGEN © 2026 | Платформа партнерских программ и SaaS-экосистема нового поколения</div>
      <div class="flex justify-center gap-6">
        <a href="https://t.me/sethubble_support" class="hover:text-cyan-400 transition-colors">Поддержка (Support)</a>
        <a href="#" class="hover:text-cyan-400 transition-colors">Публичная оферта</a>
      </div>
    </footer>

    <!-- СКРИПТЫ (Без изменений) -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const DEFAULT_BOT = "sethubble_biz_bot";
        const DEFAULT_PARTNER_ID = "p_qdr";
        
        // ⚠️ ЗАМЕНИ на реальный URL твоего API Gateway из Яндекса! ⚠️
        const API_URL = "https://d5dsbah1d4ju0glmp9d0.3zvepvee.apigw.yandexcloud.net/?action=web-chat";
        const WEB_CHAT_URL = "/ai/";
        const VK_COMMUNITY_URL = "https://vk.me/club237421168";

        let partnerId = null;
        let refBot = null;

        let currentSessionId = localStorage.getItem("neurogen_web_session");
        if (!currentSessionId) {
          currentSessionId = `web_${Math.random().toString(36).substring(2, 15)}_${Date.now()}`;
          localStorage.setItem("neurogen_web_session", currentSessionId);
        }

        const urlParams = new URLSearchParams(window.location.search);
        let encodedId = urlParams.get("page");

        const fromHex = (hex) => {
          try {
            if (!/^[0-9a-fA-F]+$/.test(hex)) return null;
            if (hex.length % 2 !== 0) return null;
            let str = "";
            for (let i = 0; i < hex.length; i += 2) {
              str += String.fromCharCode(parseInt(hex.substr(i, 2), 16));
            }
            return str;
          } catch (e) {
            return null;
          }
        };

        if (encodedId) {
          const decoded = fromHex(encodedId);
          partnerId = (decoded && decoded.length > 1) ? decoded.trim() : encodedId.trim();
          if (partnerId) localStorage.setItem("neurogen_partner_id", partnerId);
        }

        if (!partnerId) {
          partnerId = localStorage.getItem("neurogen_partner_id") || DEFAULT_PARTNER_ID;
        }

        const storedBot = localStorage.getItem("neurogen_partner_bot");
        refBot = (storedBot && storedBot !== "sethubble_bot") ? storedBot : DEFAULT_BOT;

        const badge = document.getElementById("partner-badge");
        const nameEl = document.getElementById("partner-name");
        if (badge && nameEl && partnerId !== DEFAULT_PARTNER_ID) {
          nameEl.textContent = partnerId;
          badge.classList.remove("hidden");
        }

        const urlStep = urlParams.get("step");
        const storedEmail = localStorage.getItem("neurogen_email");
        const emailVerified = localStorage.getItem("neurogen_email_verified") === "true";

        const modal = document.getElementById("leadModal");
        const modalContent = document.getElementById("modalContent");
        const btnOpenList = document.querySelectorAll(".js-open-modal");
        const btnClose = document.getElementById("closeModal");

        const stepEmail = document.getElementById("stepEmail");
        const stepChoice = document.getElementById("stepChoice");
        const stepRemembered = document.getElementById("stepRemembered");
        const emailForm = document.getElementById("emailForm");
        const emailInput = document.getElementById("userEmail");
        const emailError = document.getElementById("emailError");
        const submitEmailBtn = document.getElementById("submitEmailBtn");

        const btnWeb = document.getElementById("btnWeb");
        const btnTelegram = document.getElementById("btnTelegram");
        const btnVK = document.getElementById("btnVK");
        const btnEmailEl = document.getElementById("btnEmail");

        function showStepChoice() {
          stepEmail.classList.add("hidden");
          stepChoice.classList.remove("hidden");
          stepRemembered.classList.add("hidden");
          document.getElementById("email-submitted").classList.add("hidden");
          if (emailVerified && btnEmailEl) {
            btnEmailEl.classList.add("hidden");
          }
        }

        function openModal() {
          modal.classList.remove("hidden");
          setTimeout(() => {
            modal.classList.remove("opacity-0");
            modalContent.classList.add("modal-enter-active");
          }, 10);
          emailInput.focus();
        }

        function closeModal() {
          modal.classList.add("opacity-0");
          modalContent.classList.remove("modal-enter-active");
          setTimeout(() => {
            modal.classList.add("hidden");
          }, 300);
        }

        btnOpenList.forEach(btn => btn.addEventListener("click", openModal));
        btnClose.addEventListener("click", closeModal);
        modal.addEventListener("click", (e) => {
          if (e.target === modal) closeModal();
        });

        if (emailVerified && storedEmail && urlStep === "channels") {
          openModal();
          showStepChoice();
          const rememberedEmailEl = document.getElementById("remembered-email-msg");
          if (rememberedEmailEl) rememberedEmailEl.textContent = storedEmail;
        } else if (emailVerified && storedEmail) {
          openModal();
          stepEmail.classList.add("hidden");
          stepChoice.classList.add("hidden");
          document.getElementById("email-submitted").classList.add("hidden");
          stepRemembered.classList.remove("hidden");
          const rememberedEmailEl = document.getElementById("remembered-email-msg");
          if (rememberedEmailEl) rememberedEmailEl.textContent = storedEmail;
        } else if (urlStep === "channels") {
          openModal();
          showStepChoice();
        }

        emailForm.addEventListener("submit", async (e) => {
          e.preventDefault();
          const email = emailInput.value.trim();
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

          if (!emailRegex.test(email)) {
            emailError.classList.remove("hidden");
            return;
          }

          emailError.classList.add("hidden");
          submitEmailBtn.innerHTML = "<span class=\"animate-pulse\">ОТПРАВКА...</span>";
          submitEmailBtn.disabled = true;

          try {
            const res = await fetch(API_URL, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                isEmail: true,
                email: email,
                partner_id: partnerId,
                sessionId: currentSessionId,
              }),
            });
            const data = await res.json();
            localStorage.setItem("neurogen_email", email);
            localStorage.setItem("neurogen_email_submitted", "true");

            stepEmail.classList.add("hidden");
            stepChoice.classList.add("hidden");
            const emailSubmittedEl = document.getElementById("email-submitted");
            if (emailSubmittedEl) {
              emailSubmittedEl.classList.remove("hidden");
              const emailMsgEl = document.getElementById("email-submitted-msg");
              if (emailMsgEl) emailMsgEl.textContent = email;
              if (data.emailAlreadyRegistered) {
                const h3 = emailSubmittedEl.querySelector("h3");
                const pBelow = emailSubmittedEl.querySelector("p.text-xs");
                if (h3) h3.textContent = "Этот email уже зарегистрирован";
                if (pBelow) pBelow.textContent = "На вашу почту отправлена ссылка для подтверждения доступа. Это для безопасности вашего аккаунта.";
              }
            }
          } catch (err) {
            console.log("API error, but proceeding local storage save.");
            localStorage.setItem("neurogen_email", email);
            localStorage.setItem("neurogen_email_submitted", "true");
            stepEmail.classList.add("hidden");
            stepChoice.classList.add("hidden");
            const emailSubmittedEl = document.getElementById("email-submitted");
            if (emailSubmittedEl) emailSubmittedEl.classList.remove("hidden");
          }
        });

        document.getElementById("btnProceedToChannels")?.addEventListener("click", () => {
          stepRemembered.classList.add("hidden");
          showStepChoice();
        });

        function encodeEmailForUrl(email) {
          if (!email) return "";
          return btoa(email).replace(/\+/g, "-").replace(/\//g, "_").replace(/=/g, "");
        }

        btnTelegram.addEventListener("click", () => {
          const email = emailInput.value.trim() || storedEmail;
          const startPayload = email ? `${partnerId}-${encodeEmailForUrl(email)}` : partnerId;
          window.location.href = `https://t.me/${refBot}?start=${startPayload}`;
        });

        btnVK.addEventListener("click", () => {
          const email = emailInput.value.trim() || storedEmail;
          const startPayload = email ? `${partnerId}-${encodeEmailForUrl(email)}` : partnerId;
          window.location.href = `${VK_COMMUNITY_URL}?ref=${startPayload}`;
        });

        btnWeb.addEventListener("click", () => {
          window.location.href = `${WEB_CHAT_URL}?ref=${partnerId}`;
        });

        btnEmailEl.addEventListener("click", () => {
          const email = emailInput.value.trim();
          stepChoice.innerHTML = `
            <div class="text-center">
              <div class="w-16 h-16 bg-gradient-to-br from-green-400 to-emerald-500 rounded-full flex items-center justify-center text-2xl mx-auto mb-4 shadow-lg shadow-green-500/20">📧</div>
              <h3 class="text-2xl font-bold text-white mb-2">Письмо уже в пути!</h3>
              <p class="text-sm text-gray-400 mb-4">Мы отправим пошаговую инструкцию на <b>${email || "твой email"}</b>.</p>
            </div>`;
        });
      });
    </script>
  </body>
</html>