          <div
            class="js-open-modal cursor-pointer relative inline-flex group w-full md:w-auto"
            role="button"
            tabindex="0"
          >
            <div class="absolute transition-all duration-1000 opacity-70 -inset-px bg-gradient-to-r from-cyan-400 via-purple-500 to-blue-500 rounded-xl blur-lg group-hover:opacity-100 group-hover:-inset-1 group-hover:duration-200">
            </div>
            <div class="relative w-full md:w-auto inline-flex items-center justify-center px-10 py-5 text-xl font-bold text-white transition-all duration-200 bg-gray-900 rounded-xl gap-3">
              <span class="content-default block"
              >⚡ НАЧАТЬ НАСТРОЙКУ БЕСПЛАТНО</span>
              <span class="content-b2b hidden"
              >⚡ ПОЛУЧИТЬ СИСТЕМУ БЕСПЛАТНО</span>
            </div>
          </div>
        </div>
      </section>
    </main>

    <!-- МОДАЛЬНОЕ ОКНО: Email + Выбор Платформы -->
    <div
      id="leadModal"
      class="hidden fixed inset-0 z-50 flex items-center justify-center px-4 bg-black/80 backdrop-blur-sm transition-opacity duration-300 opacity-0"
    >
      <div
        id="modalContent"
        class="modal-enter w-full max-w-md bg-[#0a0a0a] border border-white/10 rounded-3xl p-6 relative shadow-2xl"
      >
        <button
          id="closeModal"
          class="absolute top-4 right-4 text-gray-500 hover:text-white transition-colors"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"
            >
            </path>
          </svg>
        </button>

        <!-- ШАГ 1: Сбор Email -->
        <div id="stepEmail" class="block">
          <div class="text-center mb-6">
            <div class="w-16 h-16 bg-gradient-to-br from-cyan-500 to-purple-600 rounded-full flex items-center justify-center text-2xl mx-auto mb-4 shadow-lg shadow-purple-500/20">
              📧
            </div>
            <h3 class="text-2xl font-bold text-white mb-2">
              Куда отправить доступы?
            </h3>
            <p class="text-sm text-gray-400">
              Мы пришлем резервную ссылку на твою систему и материалы.
            </p>
          </div>
          <form id="emailForm" class="space-y-4">
            <div>
              <input
                type="text"
                id="userName"
                required
                placeholder="Ваше имя (или псевдоним)"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-all text-center text-lg mb-3"
              >
              <input
                type="email"
                id="userEmail"
                required
                placeholder="твой@email.com"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition-all text-center text-lg"
              >
            </div>

            <!-- Мотивация + Предупреждение -->
            <div class="bg-purple-900/20 border border-purple-500/30 p-3 rounded-lg text-[11px] text-gray-400 text-left leading-tight">
              ⚠️ <b>Внимание:</b> Укажите корректное имя. Именно оно будет
              отображаться на <b>вашем личном сайте</b> для приглашенных вами
              партнеров.
            </div>

            <button
              type="submit"
              id="submitEmailBtn"
              class="w-full bg-gradient-to-r from-cyan-500 to-purple-500 text-white font-bold py-3.5 rounded-xl hover:opacity-90 transition-opacity flex justify-center items-center gap-2"
            >
              ПРОДОЛЖИТЬ
            </button>
            <p id="emailError" class="text-red-400 text-xs text-center hidden">
              Пожалуйста, проверьте данные
            </p>
          </form>
          <p class="text-[10px] text-gray-500 text-center mt-4">
            Нажимая кнопку, ты соглашаешься с политикой конфиденциальности.
          </p>
        </div>

        <!-- ШАГ 2: Выбор платформы -->
        <div id="stepChoice" class="hidden">
          <div class="text-center mb-6">
            <div class="w-16 h-16 bg-gradient-to-br from-green-400 to-blue-500 rounded-full flex items-center justify-center text-2xl mx-auto mb-4 shadow-lg shadow-blue-500/20">
              ✅
            </div>
            <h3 class="text-2xl font-bold text-white mb-2">Отлично!</h3>
            <p class="text-sm text-gray-400">
              Где тебе удобнее пройти настройку?
            </p>
          </div>
          <div class="space-y-3">
            <button
              id="btnTelegram"
              class="w-full relative group overflow-hidden bg-[#2AABEE]/10 border border-[#2AABEE]/30 hover:border-[#2AABEE] rounded-xl p-4 text-left transition-all flex items-center gap-4"
            >
              <div class="text-3xl">✈️</div>
              <div>
                <div class="font-bold text-white group-hover:text-[#2AABEE] transition-colors">
                  Через Telegram-бота
                </div>
                <div class="text-xs text-gray-400">
                  Быстро, удобно, всё в мессенджере
                </div>
              </div>
            </button>
            <button
              id="btnVK"
              class="w-full relative group overflow-hidden bg-[#0077FF]/10 border border-[#0077FF]/30 hover:border-[#0077FF] rounded-xl p-4 text-left transition-all flex items-center gap-4"
            >
              <div class="text-3xl">💬</div>
              <div>
                <div class="font-bold text-white group-hover:text-[#0077FF] transition-colors">
                  Через ВКонтакте
                </div>
                <div class="text-xs text-gray-400">
                  Не заблокирован, аудитория 80M+ в РФ
                </div>
              </div>
            </button>
            <button
              id="btnWeb"
              class="w-full relative group overflow-hidden bg-white/5 border border-white/10 hover:border-cyan-500/50 rounded-xl p-4 text-left transition-all flex items-center gap-4"
            >
              <div class="text-3xl">🌐</div>
              <div>
                <div class="font-bold text-white group-hover:text-cyan-400 transition-colors">
                  Через Web-сайт
                </div>
                <div class="text-xs text-gray-400">
                  Работает в любом браузере, без VPN
                </div>
              </div>
            </button>
            <button
              id="btnEmail"
              class="w-full relative group overflow-hidden bg-white/5 border border-white/10 hover:border-green-500/50 rounded-xl p-4 text-left transition-all flex items-center gap-4 hidden"
            >
              <div class="text-3xl">📧</div>
              <div>
                <div class="font-bold text-white group-hover:text-green-400 transition-colors">
                  Email-рассылка
                </div>
                <div class="text-xs text-gray-400">
                  Пошаговая настройка через email
                </div>
              </div>
            </button>
          </div>
        </div>

        <div id="email-submitted" class="hidden"></div>
        <div id="stepRemembered" class="hidden"></div>
      </div>
    </div>

    <footer class="w-full max-w-5xl mx-auto py-8 text-center text-gray-600 text-xs border-t border-gray-800/50 mt-10">
      <!-- Партнерский бейдж (SetHubble ID) перенесен вниз -->
      <div
        id="partner-badge"
        class="hidden justify-center items-center gap-2 mb-4"
      >
        <span class="text-gray-500 uppercase tracking-wider"
        >SetHubble ID партнера:</span>
        <span
          id="partner-name"
          class="font-bold text-gray-400 tracking-widest"
        ></span>
      </div>

      <div id="footer-text" class="mb-4">
        NEUROGEN © 2026 | Платформа партнерских программ и SaaS-экосистема
        нового поколения
      </div>
      <div class="flex justify-center gap-6">
        <a
          href="https://t.me/sethubble_support"
          class="hover:text-cyan-400 transition-colors"
        >Поддержка (Support)</a>
        <a href="#" class="hover:text-cyan-400 transition-colors"
        >Публичная оферта</a>
      </div>
    </footer>

    <!-- JS ЛОГИКА -->
    <script>
    document.addEventListener("DOMContentLoaded", () => {
  const DEFAULT_BOT = "sethubble_biz_bot";
  const DEFAULT_PARTNER_ID = "p_qdr";
  const BASE_API_URL =
    "https://d5dsbah1d4ju0glmp9d0.3zvepvee.apigw.yandexcloud.net/";
  const API_URL = BASE_API_URL + "?action=web-chat";
  const WEB_CHAT_URL = "/ai/";
  const VK_COMMUNITY_URL = "https://vk.me/club237421168";

  // === CSS TOGGLE LOGIC ===
  const urlParams = new URLSearchParams(window.location.search);
  const isB2b = urlParams.get("role") === "b2b";

  if (isB2b) {
    document.querySelectorAll(".content-default").forEach(el =>
      el.classList.add("hidden")
    );
    document.querySelectorAll(".content-b2b").forEach(el =>
      el.classList.remove("hidden")
    );
    document.getElementById("footer-text").textContent =
      "NEUROGEN © 2026 | Официальный партнёр — ООО \"НейроДиджитал\"";
  }

  // === Инициализация параметров ===
  let partnerId = null;
  let refBot = null;
  let currentSessionId = localStorage.getItem("neurogen_web_session");
  if (!currentSessionId) {
    currentSessionId = `web_${
      Math.random().toString(36).substring(2, 15)
    }_${Date.now()}`;
    localStorage.setItem("neurogen_web_session", currentSessionId);
  }

  let encodedId = urlParams.get("page");
  let refFromUrl = urlParams.get("ref");

  const fromHex = (hex) => {
    try {
      if (!/^[0-9a-fA-F]+$/.test(hex)) return null;
      if (hex.length % 2 !== 0) return null;
      let str = "";
      for (let i = 0; i < hex.length; i += 2) {
        str += String.fromCharCode(parseInt(hex.substr(i, 2), 16));
      }
      return str;
    } catch (e) {
      return null;
    }
  };

  if (encodedId) {
    const decoded = fromHex(encodedId);
    partnerId = (decoded && decoded.length > 1)
      ? decoded.trim()
      : encodedId.trim();
    if (partnerId) localStorage.setItem("neurogen_partner_id", partnerId);
  } else if (refFromUrl) {
    partnerId = refFromUrl.trim();
    if (partnerId) localStorage.setItem("neurogen_partner_id", partnerId);
  }

  if (!partnerId) {
    partnerId = localStorage.getItem("neurogen_partner_id")
      || DEFAULT_PARTNER_ID;
  }

  const storedBot = localStorage.getItem("neurogen_partner_bot");
  refBot = (storedBot && storedBot !== "sethubble_bot")
    ? storedBot
    : DEFAULT_BOT;

  // === ДИНАМИЧЕСКИЕ КАНАЛЫ (Запрос к API) ===
  async function fetchPublicConfig() {
    try {
      const res = await fetch(BASE_API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ action: "get_public_config", page: partnerId }),
      });
      const config = await res.json();

      // Скрываем каналы, которые партнер не настроил
      if (!config.telegram) {
        document.getElementById("btnTelegram").classList.add("hidden");
      }
      if (!config.vk) document.getElementById("btnVK").classList.add("hidden");
      if (!config.email) {
        document.getElementById("btnEmail").classList.add("hidden");
      }

      // Отображаем ИМЯ и ID партнера в подвале
      const badge = document.getElementById("partner-badge");
      const nameEl = document.getElementById("partner-name");
      if (badge && nameEl && config.first_name) {
        // Пишем: Имя (ID: ХХХ)
        nameEl.textContent = `${config.first_name} (ID: ${
          config.sh_user_id || "Скрыт"
        })`;
        badge.classList.remove("hidden");
        badge.classList.add("flex");
      }
    } catch (e) {
      console.error("Failed to fetch public config", e);
      // Fallback (показываем текстовый хвост, если API недоступно)
      const badge = document.getElementById("partner-badge");
      const nameEl = document.getElementById("partner-name");
      if (badge && nameEl && partnerId !== DEFAULT_PARTNER_ID) {
        nameEl.textContent = String(partnerId).toUpperCase();
        badge.classList.remove("hidden");
        badge.classList.add("flex");
      }
    }
  }
  fetchPublicConfig();

  // === Логика модального окна ===
  const modal = document.getElementById("leadModal");
  const modalContent = document.getElementById("modalContent");
  const btnOpenList = document.querySelectorAll(".js-open-modal");
  const btnClose = document.getElementById("closeModal");
  const stepEmail = document.getElementById("stepEmail");
  const stepChoice = document.getElementById("stepChoice");
  const emailForm = document.getElementById("emailForm");
  const emailInput = document.getElementById("userEmail");

  function openModal() {
    modal.classList.remove("hidden");
    setTimeout(() => {
      modal.classList.remove("opacity-0");
      modalContent.classList.add("modal-enter-active");
    }, 10);
    emailInput.focus();
  }

  function closeModal() {
    modal.classList.add("opacity-0");
    modalContent.classList.remove("modal-enter-active");
    setTimeout(() => {
      modal.classList.add("hidden");
    }, 300);
  }

  btnOpenList.forEach(btn => btn.addEventListener("click", openModal));
  btnClose.addEventListener("click", closeModal);
  modal.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  emailForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    const name = document.getElementById("userName").value.trim();
    const emailError = document.getElementById("emailError");
    const submitEmailBtn = document.getElementById("submitEmailBtn");

    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email) || !name) {
      emailError.classList.remove("hidden");
      return;
    }

    emailError.classList.add("hidden");
    submitEmailBtn.innerHTML =
      "<span class=\"animate-pulse\">ОТПРАВКА...</span>";
    submitEmailBtn.disabled = true;

    try {
      await fetch(API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          isEmail: true,
          email: email,
          first_name: name,
          partner_id: partnerId,
          sessionId: currentSessionId,
        }),
      });
    } catch (err) {
      console.log("API error ignored");
    }

    localStorage.setItem("neurogen_email", email);
    localStorage.setItem("neurogen_name", name);
    localStorage.setItem("neurogen_email_submitted", "true");

    // Скрываем форму и показываем экран "Письмо отправлено"
    stepEmail.classList.add("hidden");
    stepChoice.classList.add("hidden");

    const emailSubmittedEl = document.getElementById("email-submitted");
    if (emailSubmittedEl) {
      emailSubmittedEl.classList.remove("hidden");
      emailSubmittedEl.innerHTML = `
            <div class="text-center mb-6">
              <div class="w-16 h-16 bg-gradient-to-br from-green-400 to-emerald-500 rounded-full flex items-center justify-center text-2xl mx-auto mb-4 shadow-lg shadow-green-500/20">✉️</div>
              <h3 class="text-2xl font-bold text-white mb-2">Проверь свою почту!</h3>
              <p class="text-sm text-gray-400 mb-2">Мы отправили ссылку для подтверждения на:</p>
              <p class="text-lg font-bold text-green-400 mb-4">${email}</p>
              <p class="text-xs text-gray-500">Перейди по ссылке в письме, чтобы подтвердить email и продолжить настройку.</p>
            </div>
          `;
    }
  });

  // Переходы на платформы
  document.getElementById("btnTelegram").addEventListener("click", () => {
    window.open(
      `https://t.me/${refBot}?start=${partnerId}__${currentSessionId}`,
      "_blank",
    );
  });

  document.getElementById("btnVK").addEventListener("click", () => {
    window.open(
      `${VK_COMMUNITY_URL}?ref=${partnerId}__${currentSessionId}`,
      "_blank",
    );
  });

  document.getElementById("btnWeb").addEventListener("click", () => {
    const email = emailInput.value.trim();
    let url = `${WEB_CHAT_URL}?ref=${partnerId}&session_id=${currentSessionId}`;
    if (isB2b) url += `&role=b2b`;
    if (email) url += `&email=${encodeURIComponent(email)}`;
    window.open(url, "_blank");
  });
});
    </script>
  </body>
</html>
