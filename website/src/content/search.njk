---
title: "Поиск по блогу"
description: "Найдите статьи, новости и материалы по интересующим вас темам."
layout: layouts/base.njk
permalink: /search/index.html
eleventyExcludeFromCollections: true
---

<section class="search-page">
	<h1>{{ title }}</h1>
	<p class="search-intro">{{ description }}</p>

	<div class="search-box">
		<input type="text" id="searchInput" placeholder="Введите запрос..." autocomplete="off">
		<button id="searchBtn" aria-label="Найти">
			<svg viewBox="0 0 24 24" width="24" height="24"><path fill="currentColor" d="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" /></svg>
		</button>
	</div>

	<div id="searchResults" class="search-results" aria-live="polite"></div>
</section>

<script type="module">
	import Fuse from 'https://cdn.jsdelivr.net/npm/fuse.js@7.0.0/dist/fuse.min.js';

	let searchIndex = null;
	let fuse = null;

	// Загрузка индекса поиска
	async function loadSearchIndex() {
		try {
			const response = await fetch('/search-index.json');
			const data = await response.json();
			
			const allContent = [
				...data.posts.map(p => ({ ...p, type: 'post' })),
				...data.news.map(n => ({ ...n, type: 'news' }))
			];

			fuse = new Fuse(allContent, {
				keys: ['title', 'description', 'content', 'tags'],
				threshold: 0.3,
				includeMatches: true,
				minMatchCharLength: 2,
				ignoreLocation: true
			});
		} catch (e) {
			console.error('Ошибка загрузки поиска:', e);
		}
	}

	// Поиск и отображение результатов
	function performSearch(query) {
		const resultsContainer = document.getElementById('searchResults');
		
		if (!query || query.length < 2) {
			resultsContainer.innerHTML = '';
			return;
		}

		if (!fuse) return;

		const results = fuse.search(query).slice(0, 20);

		if (results.length === 0) {
			resultsContainer.innerHTML = '<p class="no-results">Ничего не найдено. Попробуйте другой запрос.</p>';
			return;
		}

		resultsContainer.innerHTML = `
			<p class="results-count">Найдено: ${results.length}</p>
			<div class="results-list">
				${results.map(r => `
					<article class="result-item ${r.item.type}">
						<span class="result-type">${r.item.type === 'post' ? '📄 Статья' : '📰 Новость'}</span>
						<h3><a href="${r.item.url}">${highlightMatch(r.item.title, query)}</a></h3>
						<p class="result-meta">
							<time>${formatDate(r.item.date)}</time>
							${r.item.tags && r.item.tags.length ? `
								<span class="result-tags">${r.item.tags.slice(0, 3).map(t => `#${t}`).join(' ')}</span>
							` : ''}
						</p>
						<p class="result-excerpt">${highlightMatch(r.item.description || r.item.content.substring(0, 150) + '...', query)}</p>
					</article>
				`).join('')}
			</div>
		`;
	}

	// Подсветка совпадений
	function highlightMatch(text, query) {
		const regex = new RegExp(`(${query})`, 'gi');
		return text.replace(regex, '<mark>$1</mark>');
	}

	// Форматирование даты
	function formatDate(dateStr) {
		return new Date(dateStr).toLocaleDateString('ru-RU', {
			year: 'numeric',
			month: 'long',
			day: 'numeric'
		});
	}

	// Инициализация
	document.addEventListener('DOMContentLoaded', () => {
		loadSearchIndex();

		const input = document.getElementById('searchInput');
		const btn = document.getElementById('searchBtn');
		let timeout = null;

		input.addEventListener('input', (e) => {
			clearTimeout(timeout);
			timeout = setTimeout(() => {
				performSearch(e.target.value.trim());
			}, 300);
		});

		btn.addEventListener('click', () => {
			performSearch(input.value.trim());
		});

		input.addEventListener('keypress', (e) => {
			if (e.key === 'Enter') {
				performSearch(input.value.trim());
			}
		});
	});
</script>

<style>
