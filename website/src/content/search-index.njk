---
permalink: /search-index.json
eleventyExcludeFromCollections: true
layout: false
---
{%- set posts = collections.posts -%}
{%- set news = collections.news -%}
{
  "posts": [
    {%- for post in posts %}
    {
      "title": {{ post.data.title | dump | safe }},
      "url": {{ post.url | dump | safe }},
      "date": "{{ post.date | htmlDateString }}",
      "description": {{ (post.data.description or "") | dump | safe }},
      "tags": {{ (post.data.tags | filterTagList or []) | dump | safe }},
      "content": {{ (post.templateContent | striptags | truncate(500) or "") | dump | safe }}
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ],
  "news": [
    {%- for item in news %}
    {
      "title": {{ item.data.title | dump | safe }},
      "url": {{ item.url | dump | safe }},
      "date": "{{ item.date | htmlDateString }}",
      "description": {{ (item.data.description or "") | dump | safe }},
      "content": {{ (item.templateContent | striptags | truncate(500) or "") | dump | safe }}
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
