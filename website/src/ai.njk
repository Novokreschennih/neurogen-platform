    <script>
    (function() {
  "use strict";

  // === КОНФИГУРАЦИЯ ===
  const API_URL =
    "https://d5dsbah1d4ju0glmp9d0.3zvepvee.apigw.yandexcloud.net/?action=web-chat";
  const DEFAULT_BOT = "sethubble_biz_bot";
  const DEFAULT_PARTNER = "p_qdr";

  // === СОСТОЯНИЕ ===
  let referrer = "";
  let userEmail = "";
  let selectedChannels = new Set();
  let setupStep = 0;
  let setupQueue = [];
  let chatHistory = [];
  let isWaiting = false;
  let neuroCoins = 0;

  // === 0. СТАБИЛЬНЫЙ SESSION ID ДЛЯ WEB-КАНАЛА ===
  let currentSessionId = localStorage.getItem("neurogen_web_session");
  if (!currentSessionId) {
    currentSessionId = `web_${
      crypto.randomUUID
        ? crypto.randomUUID()
        : Math.random().toString(36).substring(2, 15)
    }_${Date.now()}`;
    localStorage.setItem("neurogen_web_session", currentSessionId);
  }

  // === 1. ПЕРЕХВАТ РЕФЕРАЛА ===
  function captureReferral() {
    const params = new URLSearchParams(window.location.search);
    const ref = params.get("ref");
    if (ref) {
      referrer = ref;
      localStorage.setItem("neurogen_partner_id", ref);
    } else {
      referrer = localStorage.getItem("neurogen_partner_id") || DEFAULT_PARTNER;
    }

    // Читаем session_id из URL (для склейки профилей)
    const urlSessionId = params.get("session_id");
    if (urlSessionId) {
      currentSessionId = urlSessionId;
      localStorage.setItem("neurogen_web_session", urlSessionId);
    }

    // Читаем email из URL (для склейки профилей)
    userEmail = params.get("email");
    if (userEmail) {
      localStorage.setItem("neurogen_user_email", userEmail);
    }

    // Обновляем ссылку на каналы с partner_id
    const channelsLink = document.getElementById("channelsLink");
    if (channelsLink && referrer) {
      const encodedRef = encodeURIComponent(referrer);
      channelsLink.href = `/join/?page=${encodedRef}&step=channels`;
    }
  }

  // === 2. НАВИГАЦИЯ ПО ЭКРАНАМ ===
  function showScreen(screenId) {
    document.querySelectorAll(".funnel-screen").forEach(s =>
      s.classList.remove("active")
    );
    const screen = document.getElementById(screenId);
    if (screen) screen.classList.add("active");
  }

  // === 3. ЗАГРУЗКА И ОТРИСОВКА ШАГОВ ВОРОНКИ (НОВОЕ) ===
  async function loadWebStep(buttonAction = null, buttonText = null) {
    // НОВОЕ: Если нажали кнопку с текстом, рисуем её в чате как сообщение пользователя
    if (buttonText && buttonAction !== "MAIN_MENU") {
      addMessage(buttonText, true, false);
      chatHistory.push({ role: "user", content: buttonText });
    }

    showTyping();
    try {
      const response = await fetch(API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          action: buttonAction ? "click-button" : "get-web-step",
          sessionId: currentSessionId,
          email: userEmail,
          callback_data: buttonAction,
          partner_id: referrer,
          // НОВОЕ: Передаем текст кнопки на сервер для сохранения в dialog_history
          message: buttonText || "",
          // НОВОЕ: Передаем имя из localStorage, если оно сохранено
          first_name: localStorage.getItem("neurogen_name") || "",
        }),
      });

      const data = await response.json();
      removeTyping();

      if (data.success) {
        renderStepData(data);
      } else if (data.error === "Session not found") {
        // Если сессия потерялась, возвращаем на ввод Email
        showScreen("screenEmail");
      }
    } catch (err) {
      console.error("Ошибка загрузки шага воронки:", err);
      removeTyping();
    }
  }

  function renderStepData(data) {
    const chatArea = document.getElementById("trainingContent");

    // 1. Убираем кнопки предыдущего шага
    const oldBtns = document.getElementById("active-buttons");
    if (oldBtns) oldBtns.remove();

    // 2. Отрисовываем картинку шага
    if (data.image) {
      const imgContainer = document.createElement("div");
      imgContainer.className = "w-full max-w-sm mx-auto mb-4 msg-animate"; // Упростили классы
      // Заменили на простой тег img с базовыми классами, которые точно есть
      imgContainer.innerHTML =
        `<img src="${data.image}" alt="step image" class="w-full rounded-2xl shadow-lg border border-gray-800">`;
      chatArea.appendChild(imgContainer);
    }

    // 3. Выводим текст шага
    addMessage(data.text, false, true);

    // 4. Генерируем кнопки
    if (data.buttons && data.buttons.length > 0) {
      const btnWrapper = document.createElement("div");
      btnWrapper.id = "active-buttons";
      btnWrapper.className = "flex flex-col gap-2 mt-4 mb-8 msg-animate";

      data.buttons.forEach(row => {
        row.forEach(btn => {
          const b = document.createElement("button");
          b.className =
            "w-full py-4 px-5 rounded-2xl bg-white/5 border border-white/10 text-white text-sm font-bold hover:bg-white/10 hover:border-purple-500/50 transition-all text-left flex justify-between items-center group";

          if (btn.url) {
            // Обычные ссылки
            b.innerHTML =
              `<span>${btn.text}</span> <span class="opacity-30 text-xs">↗</span>`;
            b.onclick = () => window.open(btn.url, "_blank");
          } else if (btn.web_app && btn.web_app.url) {
            // WebApp ссылки (Promo-Kit, CRM)
            b.innerHTML =
              `<span>${btn.text}</span> <span class="opacity-30 text-xs">↗</span>`;
            b.onclick = () => window.open(btn.web_app.url, "_blank");
          } else {
            // Обычные кнопки (Callback)
            b.innerHTML =
              `<span>${btn.text}</span> <span class="group-hover:translate-x-1 transition-transform text-cyan-400">→</span>`;
            b.onclick = () => loadWebStep(btn.callback_data, btn.text);
          }
          btnWrapper.appendChild(b);
        });
      });
      chatArea.appendChild(btnWrapper);
    }

    // Обновляем индикатор в хедере
    if (document.getElementById("trainingStep")) {
      document.getElementById("trainingStep").textContent = data.stepKey;
    }
    scrollToBottom();
  }

  // === 4. ОБРАБОТКА EMAIL ФОРМЫ ===
  const emailForm = document.getElementById("emailForm");
  const emailInput = document.getElementById("funnelEmail");
  const emailError = document.getElementById("emailError");
  const emailBtn = document.getElementById("funnelEmailBtn");

  emailForm.addEventListener("submit", async function(e) {
    e.preventDefault();
    const email = emailInput.value.trim();
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    if (!emailRegex.test(email)) {
      emailError.classList.remove("hidden");
      return;
    }
    emailError.classList.add("hidden");
    emailBtn.disabled = true;
    emailBtn.innerHTML = "<span class=\"animate-pulse\">ОТПРАВКА...</span>";

    try {
      await fetch(API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          isEmail: true,
          email: email,
          partner_id: referrer,
          sessionId: currentSessionId,
        }),
      });
      userEmail = email;
      localStorage.setItem("neurogen_email", email);
      localStorage.setItem("neurogen_email_submitted", "true");

      // После ввода Email сразу переходим к воронке
      showScreen("screenTraining");
      loadWebStep();
    } catch (err) {
      console.error("Email save failed");
      showScreen("screenTraining");
      loadWebStep();
    }
  });

  // === 5. ЧАТ И UI ФУНКЦИИ ===
  // === 5. ЧАТ И UI ФУНКЦИИ ===
  function addMessage(text, isUser, isHTML) {
    const chatArea = document.getElementById("trainingContent");

    const wrapper = document.createElement("div");
    // Добавляем margin-bottom (mb-4) для разделения сообщений
    wrapper.className = "flex w-full mb-4 msg-animate "
      + (isUser ? "justify-end" : "justify-start");

    const bubble = document.createElement("div");
    bubble.className =
      "max-w-[85%] md:max-w-[70%] rounded-2xl px-5 py-4 text-base leading-relaxed break-words shadow-lg "
      + (isUser
        ? "bg-gradient-to-r from-cyan-500 to-purple-500 text-white rounded-br-sm"
        : "bg-gray-800/90 text-gray-100 rounded-bl-sm border border-white/5");

    // Если это текст от ИИ/воронки, заменяем переносы строк (\n) на <br> для правильного отображения
    let processedText = text;
    if (isHTML && typeof text === "string") {
      processedText = text.replace(/\n/g, "<br>");
      bubble.innerHTML = processedText;
    } else {
      bubble.textContent = text;
    }

    wrapper.appendChild(bubble);
    chatArea.appendChild(wrapper);
    scrollToBottom();
  }

  function showTyping() {
    if (document.getElementById("typingIndicator")) return;
    const chatArea = document.getElementById("trainingContent");
    const wrapper = document.createElement("div");
    wrapper.id = "typingIndicator";
    wrapper.className = "flex w-full justify-start msg-animate";
    wrapper.innerHTML =
      `<div class="bg-gray-800/80 rounded-2xl rounded-bl-md px-5 py-4 flex items-center gap-1.5">
                            <span class="typing-dot w-2 h-2 bg-gray-400 rounded-full inline-block"></span>
                            <span class="typing-dot w-2 h-2 bg-gray-400 rounded-full inline-block"></span>
                            <span class="typing-dot w-2 h-2 bg-gray-400 rounded-full inline-block"></span>
                         </div>`;
    chatArea.appendChild(wrapper);
    scrollToBottom();
  }

  function removeTyping() {
    const el = document.getElementById("typingIndicator");
    if (el) el.remove();
  }

  function scrollToBottom() {
    const chatArea = document.getElementById("trainingContent");
    if (chatArea) {
      requestAnimationFrame(() => {
        chatArea.scrollTop = chatArea.scrollHeight;
      });
    }
  }

  // === 6. ОБРАБОТКА СВОБОДНОГО ЧАТА С ИИ ===
  const chatFormEl = document.getElementById("chatForm");
  const messageInput = document.getElementById("messageInput");

  if (chatFormEl) {
    chatFormEl.addEventListener("submit", async function(e) {
      e.preventDefault();
      const text = messageInput.value.trim();
      if (!text || isWaiting) return;

      isWaiting = true;
      messageInput.value = "";
      addMessage(text, true);
      chatHistory.push({ role: "user", content: text });

      showTyping();
      try {
        const response = await fetch(API_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            message: text,
            partner_id: referrer,
            history: chatHistory.slice(-10),
            sessionId: currentSessionId,
            email: userEmail,
          }),
        });
        const data = await response.json();
        removeTyping();
        addMessage(
          data.answer || "🤖 Я немного задумался. Повтори, пожалуйста!",
          false,
          true,
        );
        chatHistory.push({ role: "assistant", content: data.answer });

        // === ДОБАВЬТЕ ЭТИ ТРИ СТРОКИ ===
        if (data.loadNextStep) {
          setTimeout(() => loadWebStep(), 1500); // Подгрузит Training_Main с кнопками через 1.5 сек
        }
      } catch (err) {
        removeTyping();
        addMessage(
          "⚠️ Связь с нейроядром прервана. Попробуй позже.",
          false,
          true,
        );
      }
      isWaiting = false;
    });
  }

  // === 7. ИНИЦИАЛИЗАЦИЯ ПРИ ЗАГРУЗКЕ ===
  captureReferral();

  const emailSubmitted = localStorage.getItem("neurogen_email_submitted");
  if (emailSubmitted === "true") {
    showScreen("screenTraining");
    loadWebStep(); // Сразу грузим текущий шаг из БД
  }

  // === ЭКСПОРТ ДЛЯ HTML ===
  window.loadWebStep = loadWebStep;

  window.toggleChannel = function(el) {
    const ch = el.dataset.channel;
    if (selectedChannels.has(ch)) {
      selectedChannels.delete(ch);
      el.classList.remove("selected");
    } else {
      selectedChannels.add(ch);
      el.classList.add("selected");
    }
    document.getElementById("btnToSetup").disabled =
      selectedChannels.size === 0;
  };

  window.goToSetup = function() {
    setupQueue = Array.from(selectedChannels);
    // (Логика отрисовки экранов настройки из старой версии может быть добавлена здесь,
    // но в v6.5 мы рекомендуем сразу переходить к loadWebStep() для фокуса на воронке)
    showScreen("screenTraining");
    loadWebStep();
  };
})();
    </script>
  </body>
</html>
