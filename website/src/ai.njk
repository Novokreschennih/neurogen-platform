    <script>
    (function() {
  "use strict";

  // === КОНФИГУРАЦИЯ ===
  const API_URL =
    "https://d5dsbah1d4ju0glmp9d0.3zvepvee.apigw.yandexcloud.net/?action=web-chat";
  const DEFAULT_BOT = "sethubble_biz_bot";
  const DEFAULT_PARTNER = "p_qdr";

  // === СОСТОЯНИЕ ===
  let referrer = "";
  let userEmail = "";
  let selectedChannels = new Set();
  let setupStep = 0;
  let setupQueue = [];
  let chatHistory = [];
  let isWaiting = false;
  let trainingStep = 1;
  let neuroCoins = 0;

  // === 1. ПЕРЕХВАТ РЕФЕРАЛА (v5.0 — partner_id) ===
  function captureReferral() {
    const params = new URLSearchParams(window.location.search);
    const ref = params.get("ref");
    if (ref) {
      // v5.0: ref — это partner_id (p_xxx)
      referrer = ref;
      try {
        localStorage.setItem("neurogen_partner_id", ref);
      } catch (e) {}
    } else {
      try {
        referrer = localStorage.getItem("neurogen_partner_id") || "";
      } catch (e) {}
    }
    if (!referrer) {
      referrer = DEFAULT_PARTNER;
    }
  }

  // === 2. НАВИГАЦИЯ ПО ЭКРАНАМ ===
  function showScreen(screenId) {
    document.querySelectorAll(".funnel-screen").forEach(s =>
      s.classList.remove("active")
    );
    const screen = document.getElementById(screenId);
    if (screen) screen.classList.add("active");
  }

  // === 3. ЭКРАН EMAIL ===
  const emailForm = document.getElementById("emailForm");
  const emailInput = document.getElementById("funnelEmail");
  const emailError = document.getElementById("emailError");
  const emailBtn = document.getElementById("funnelEmailBtn");

  emailForm.addEventListener("submit", async function(e) {
    e.preventDefault();
    const email = emailInput.value.trim();
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    if (!emailRegex.test(email)) {
      emailError.classList.remove("hidden");
      return;
    }
    emailError.classList.add("hidden");
    emailBtn.disabled = true;
    emailBtn.innerHTML = "<span class=\"animate-pulse\">ОТПРАВКА...</span>";

    // Сохраняем email (v5.0: partner_id)
    userEmail = email;
    try {
      await fetch(API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          isEmail: true,
          email: email,
          partner_id: referrer,
          referrer: referrer, // backward compat
        }),
      });
    } catch (err) {
      console.log("Email saved locally");
    }

    // Переход к выбору каналов
    setTimeout(() => showScreen("screenChannels"), 500);
  });

  // === 4. ЭКРАН КАНАЛОВ ===
  function toggleChannel(el) {
    const channel = el.dataset.channel;
    if (selectedChannels.has(channel)) {
      selectedChannels.delete(channel);
      el.classList.remove("selected");
      el.querySelector(".check-icon").textContent = "○";
      el.querySelector(".check-icon").classList.remove("text-green-400");
      el.querySelector(".check-icon").classList.add("text-gray-600");
    } else {
      selectedChannels.add(channel);
      el.classList.add("selected");
      el.querySelector(".check-icon").textContent = "✓";
      el.querySelector(".check-icon").classList.remove("text-gray-600");
      el.querySelector(".check-icon").classList.add("text-green-400");
    }
    document.getElementById("btnToSetup").disabled =
      selectedChannels.size === 0;
  }

  function goToSetup() {
    if (selectedChannels.size === 0) return;

    // Формируем очередь настройки
    setupQueue = Array.from(selectedChannels);
    setupStep = 0;
    renderSetupStep();
    showScreen("screenSetup");
  }

  // === 5. ЭКРАН НАСТРОЙКИ ===
  const setupContent = document.getElementById("setupContent");
  const setupActions = document.getElementById("setupActions");

  const setupSteps = {
    telegram: {
      title: "✈️ НАСТРОЙКА TELEGRAM",
      body: `
            <p class="text-gray-400 text-sm mb-4">Для работы Telegram-бота тебе нужно:</p>
            <ol class="text-left text-sm text-gray-300 space-y-3">
              <li class="flex gap-2"><span class="text-cyan-400 font-bold">1.</span> Напиши <a href="https://t.me/BotFather" target="_blank" class="text-cyan-400 underline">@BotFather</a> в Telegram</li>
              <li class="flex gap-2"><span class="text-cyan-400 font-bold">2.</span> Отправь команду <code class="bg-white/10 px-1.5 py-0.5 rounded text-xs">/newbot</code></li>
              <li class="flex gap-2"><span class="text-cyan-400 font-bold">3.</span> Придумай имя и username для бота</li>
              <li class="flex gap-2"><span class="text-cyan-400 font-bold">4.</span> Скопируй API-токен (вида <code class="bg-white/10 px-1.5 py-0.5 rounded text-xs">123456:ABC...</code>)</li>
              <li class="flex gap-2"><span class="text-cyan-400 font-bold">5.</span> Зарегистрируйся на <a href="https://sethubble.com/ru/" target="_blank" class="text-cyan-400 underline">sethubble.com</a> и получи свой ID</li>
            </ol>
          `,
      button: "✅ ГОТОВО, СЛЕДУЮЩИЙ ШАГ",
      link: "https://t.me/BotFather",
    },
    vk: {
      title: "💬 НАСТРОЙКА VK",
      body: `
            <p class="text-gray-400 text-sm mb-4">Для работы VK-бота тебе нужно:</p>
            <ol class="text-left text-sm text-gray-300 space-y-3">
              <li class="flex gap-2"><span class="text-indigo-400 font-bold">1.</span> Создай сообщество VK или используй существующее</li>
              <li class="flex gap-2"><span class="text-indigo-400 font-bold">2.</span> Открой «Управление» → «Работа с API»</li>
              <li class="flex gap-2"><span class="text-indigo-400 font-bold">3.</span> Создай сервисный ключ доступа</li>
              <li class="flex gap-2"><span class="text-indigo-400 font-bold">4.</span> Включи Callback API и укажи URL:</p>
              <p class="bg-white/10 px-3 py-2 rounded text-xs text-center break-all">https://d5dsbah1d4ju0glmp9d0.3zvepvee.apigw.yandexcloud.net/?action=vk-webhook</p>
              <li class="flex gap-2"><span class="text-indigo-400 font-bold">5.</span> Запомни ID сообщества (число)</li>
            </ol>
          `,
      button: "✅ ГОТОВО, СЛЕДУЮЩИЙ ШАГ",
      link: "https://vk.com",
    },
    web: {
      title: "🌐 ПОДКЛЮЧЕНИЕ ЧАТА НА САЙТЕ",
      body: `
            <p class="text-gray-400 text-sm mb-4">Чтобы AI-консультант появился на твоём сайте:</p>
            <div class="bg-white/10 rounded-lg p-3 text-left mb-4">
              <p class="text-xs text-gray-400 mb-2">Скопируй этот код:</p>
              <code class="text-[11px] text-cyan-300 break-all">&lt;script src="https://sethubble.ru/js/widget.js" data-partner="${referrer}"&gt;&lt;/script&gt;</code>
            </div>
            <p class="text-sm text-gray-300">Вставь его перед закрывающим тегом <code class="bg-white/10 px-1.5 py-0.5 rounded text-xs">&lt;/body&gt;</code> на своём сайте.</p>
          `,
      button: "✅ ГОТОВО, СЛЕДУЮЩИЙ ШАГ",
      link: null,
    },
    email: {
      title: "📧 EMAIL-РАССЫЛКА",
      body: `
            <p class="text-gray-400 text-sm mb-4">Email <b>${userEmail}</b> уже привязан к твоему аккаунту.</p>
            <p class="text-sm text-gray-300 mb-4">Ты будешь получать:</p>
            <ul class="text-left text-sm text-gray-300 space-y-2">
              <li>✅ Напоминания о продолжении обучения</li>
              <li>✅ Дожимы по офферам</li>
              <li>✅ Уведомления о новых лидах</li>
            </ul>
          `,
      button: "✅ ГОТОВО, СЛЕДУЮЩИЙ ШАГ",
      link: null,
    },
  };

  function renderSetupStep() {
    if (setupStep >= setupQueue.length) {
      // Все каналы настроены — переход к обучению
      trainingStep = 1;
      showWelcomeMessage();
      showScreen("screenTraining");
      return;
    }

    const channel = setupQueue[setupStep];
    const step = setupSteps[channel];
    const progress = `Шаг ${setupStep + 1} из ${setupQueue.length}`;

    setupContent.innerHTML = `
          <p class="text-[10px] text-gray-500 uppercase tracking-wider mb-3">${progress}</p>
          <h2 class="text-xl font-black mb-4">${step.title}</h2>
          ${step.body}
        `;

    let btnHTML =
      `<button onclick="nextSetupStep()" class="w-full bg-gradient-to-r from-cyan-500 to-purple-500 text-white font-bold py-4 rounded-xl hover:opacity-90 transition-opacity text-base">${step.button}</button>`;
    if (step.link) {
      btnHTML +=
        `<a href="${step.link}" target="_blank" rel="noopener noreferrer" class="w-full inline-flex items-center justify-center glass-panel text-white font-bold py-3 rounded-xl hover:bg-white/10 transition-all text-sm mt-2">Открыть инструкцию →</a>`;
    }
    setupActions.innerHTML = btnHTML;
  }

  function nextSetupStep() {
    neuroCoins += 10; // Начисляем за каждый пройденный шаг
    setupStep++;
    renderSetupStep();
  }

  // === 6. ЭКРАН ОБУЧЕНИЯ ===

  /**
   * v5.0: Для пользователей, пришедших с /join/
   * Пропускаем welcome-сообщение с выбором шагов обучения — сразу чат
   */
  function startTraining() {
    const chatArea = document.getElementById("trainingContent");
    if (!chatArea) return;
    chatArea.innerHTML = "";

    const welcomeText = `Привет! 🎉<br><br>
          Ты уже в системе. Я — твой ИИ-консультант SetHubble.<br>
          Спрашивай что угодно про бизнес-стратегии, воронки, партнёрскую программу.<br><br>
          Или нажми <b>«Обучение»</b> ниже, чтобы пройти 3 шага и заработать NeuroCoins:`;

    addMessage(welcomeText, false, true);

    // Показываем кнопку обучения и чат-ввод
    setTimeout(() => {
      showTrainingButtons();
    }, 600);
  }

  function showWelcomeMessage() {
    const chatArea = document.getElementById("trainingContent");
    chatArea.innerHTML = "";

    const welcomeText = `Привет! 🎉 Ты успешно настроил свою ИИ-систему.<br><br>
          Выбрано каналов: <b>${selectedChannels.size}</b><br>
          NeuroCoins заработано: <b>${neuroCoins}</b><br><br>
          Я — твой ИИ-консультант. Спрашивай что угодно про SetHubble, бизнес-стратегии и воронки. А пока — давай пройдём 3 шага обучения:`;

    addMessage(welcomeText, false, true);

    // Кнопки обучения
    setTimeout(() => {
      showTrainingButtons();
    }, 600);
  }

  function showTrainingButtons() {
    const chatArea = document.getElementById("trainingContent");
    const wrapper = document.createElement("div");
    wrapper.className = "flex w-full justify-start msg-animate";
    wrapper.id = "trainingBtns";

    const container = document.createElement("div");
    container.className =
      "bg-gray-800/80 rounded-2xl rounded-bl-md px-4 py-3 space-y-2";

    const steps = [
      { label: "📖 Шаг 1: Стратегия заработка", action: "trainingStep1" },
      { label: "💻 Шаг 2: Онлайн-бизнес", action: "trainingStep2" },
      { label: "🏬 Шаг 3: Офлайн-бизнес", action: "trainingStep3" },
    ];

    steps.forEach((s, i) => {
      const btn = document.createElement("button");
      btn.className =
        "w-full text-left px-3 py-2 rounded-lg bg-white/5 hover:bg-white/10 text-sm text-white transition-all";
      btn.textContent = s.label;
      btn.onclick = () => handleTrainingStep(i + 1);
      container.appendChild(btn);
    });

    wrapper.appendChild(container);
    chatArea.appendChild(wrapper);
    scrollToBottom();
  }

  function handleTrainingStep(step) {
    const content = {
      1: {
        text:
          `📖 <b>ШАГ 1: СТРАТЕГИЯ ЗАРАБОТКА</b><br><br>SetHubble — это не MLM и не affiliate-маркетинг. Это гибридная IT-платформа:<br>• ИИ-боты продают за тебя 24/7<br>• До 10 уровней в глубину<br>• Комиссия до 50%<br>• Пассивный доход в USDT<br><br>🪙 +20 NeuroCoins!`,
        coins: 20,
      },
      2: {
        text:
          `💻 <b>ШАГ 2: ОНЛАЙН-БИЗНЕС</b><br><br>Для блогеров и инфобизнесменов:<br>• Монетизируй даже тех, кто сказал «НЕТ»<br>• Один пост → 20,000 регистраций<br>• Все они — в твоей структуре навсегда<br><br>🪙 +20 NeuroCoins!`,
        coins: 20,
      },
      3: {
        text:
          `🏬 <b>ШАГ 3: ОФЛАЙН-БИЗНЕС</b><br><br>Технология «Троянский конь»:<br>• QR-код на кассе → клиент сканирует → становится твоим агентом<br>• O2O-генератор: офлайн → онлайн<br>• Бизнес строит тебе сеть своими руками<br><br>🪙 +20 NeuroCoins!`,
        coins: 20,
      },
    };

    const stepData = content[step];
    neuroCoins += stepData.coins;

    addMessage(stepData.text, false, true);

    // После 3-го шага — показываем оффер
    if (step === 3) {
      setTimeout(() => {
        addMessage(
          `🎉 <b>Поздравляю! Ты прошёл обучение!</b><br><br>NeuroCoins: <b>${neuroCoins}</b><br>${
            neuroCoins >= 100
              ? "✅ У тебя достаточно NeuroCoins для скидки 50% на PRO!"
              : "🔒 Ещё немного до скидки — нужно 100 NeuroCoins"
          }<br><br>Готов активировать свою систему?`,
          false,
          true,
        );

        setTimeout(() => {
          const wrapper = document.createElement("div");
          wrapper.className = "flex w-full justify-start msg-animate";

          const container = document.createElement("div");
          container.className =
            "bg-gray-800/80 rounded-2xl rounded-bl-md px-4 py-3 space-y-2";

          const offerBtn = document.createElement("a");
          offerBtn.href = "#";
          offerBtn.className =
            "w-full inline-flex items-center justify-center px-6 py-3 rounded-xl bg-gradient-to-r from-yellow-500 to-orange-500 text-white text-sm font-bold hover:opacity-90 active:scale-95 transition-all";
          offerBtn.textContent = "💎 АКТИВИРОВАТЬ PRO";
          offerBtn.onclick = (e) => {
            e.preventDefault();
            showOffer();
          };
          container.appendChild(offerBtn);

          const chatBtn = document.createElement("button");
          chatBtn.className =
            "w-full text-left px-3 py-2 rounded-lg bg-white/5 hover:bg-white/10 text-sm text-white transition-all";
          chatBtn.textContent = "💬 Задать вопрос NeuroGen";
          chatBtn.onclick = () => {
            wrapper.remove();
            messageInput.focus();
          };
          container.appendChild(chatBtn);

          wrapper.appendChild(container);
          document.getElementById("trainingContent").appendChild(wrapper);
          scrollToBottom();
        }, 600);
      }, 600);
    }
  }

  function showOffer() {
    const channelsStr = Array.from(selectedChannels).map(ch => {
      const names = {
        telegram: "✈️ TG",
        vk: "💬 VK",
        web: "🌐 Web",
        email: "📧 Email",
      };
      return names[ch] || ch;
    }).join(", ");

    document.getElementById("offerChannels").textContent = channelsStr;
    // v5.0: partner_id — это ref, ссылка на регистрацию
    document.getElementById("offerRefLink").textContent =
      `https://sethubble.com/ru/${referrer}`;
    document.getElementById("offerNeuroCoins").textContent = neuroCoins;

    showScreen("screenOffer");
  }

  // === 7. AI-ЧАТ (встроен в обучение) ===
  function createMessageBubble(text, isUser, isHTML) {
    const wrapper = document.createElement("div");
    wrapper.className = "flex w-full msg-animate";
    wrapper.classList.add(isUser ? "justify-end" : "justify-start");

    const bubble = document.createElement("div");
    bubble.className =
      "max-w-[85%] md:max-w-[70%] rounded-2xl px-4 py-3 text-sm leading-relaxed break-words";

    if (isUser) {
      bubble.classList.add(
        "bg-gradient-to-r",
        "from-cyan-500",
        "to-purple-500",
        "text-white",
        "rounded-br-md",
      );
      bubble.textContent = text;
    } else {
      bubble.classList.add("bg-gray-800/80", "text-gray-100", "rounded-bl-md");
      if (isHTML) bubble.innerHTML = text;
      else bubble.textContent = text;
    }

    wrapper.appendChild(bubble);
    return wrapper;
  }

  function addMessage(text, isUser, isHTML) {
    const chatArea = document.getElementById("trainingContent");
    if (!chatArea) return;
    const el = createMessageBubble(text, isUser, isHTML);
    chatArea.appendChild(el);
    scrollToBottom();
  }

  function showTyping() {
    const chatArea = document.getElementById("trainingContent");
    if (!chatArea || document.getElementById("typingIndicator")) return;

    const wrapper = document.createElement("div");
    wrapper.className = "flex w-full justify-start msg-animate";
    wrapper.id = "typingIndicator";

    const bubble = document.createElement("div");
    bubble.className =
      "bg-gray-800/80 rounded-2xl rounded-bl-md px-5 py-4 flex items-center gap-1.5";
    for (let i = 0; i < 3; i++) {
      const dot = document.createElement("span");
      dot.className =
        "typing-dot w-2 h-2 bg-gray-400 rounded-full inline-block";
      bubble.appendChild(dot);
    }

    wrapper.appendChild(bubble);
    chatArea.appendChild(wrapper);
    scrollToBottom();
  }

  function removeTyping() {
    const el = document.getElementById("typingIndicator");
    if (el) el.remove();
  }

  function scrollToBottom() {
    const chatArea = document.getElementById("trainingContent");
    if (chatArea) {
      requestAnimationFrame(() => {
        chatArea.scrollTop = chatArea.scrollHeight;
      });
    }
  }

  async function sendToAPI(userMessage) {
    try {
      const response = await fetch(API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          message: userMessage,
          partner_id: referrer, // v5.0
          referrer: referrer, // backward compat
          history: chatHistory.slice(-20),
          sessionId: `web_funnel_${Date.now()}`,
        }),
      });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();
      return data.answer || data.message
        || "Извини, не удалось получить ответ.";
    } catch (error) {
      console.error("API Error:", error);
      return "⚠️ Сервер временно занят. Попробуй через пару секунд!";
    }
  }

  // === 8. ОБРАБОТКА ЧАТА ===
  const chatFormEl = document.getElementById("chatForm");
  const messageInput = document.getElementById("messageInput");
  const sendBtn = document.getElementById("sendBtn");

  if (chatFormEl) {
    chatFormEl.addEventListener("submit", async function(e) {
      e.preventDefault();
      const text = messageInput.value.trim();
      if (!text || isWaiting) return;

      isWaiting = true;
      sendBtn.disabled = true;
      messageInput.disabled = true;

      addMessage(text, true);
      chatHistory.push({ role: "user", content: text });

      // Email interceptor
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (emailRegex.test(text)) {
        userEmail = text;
        addMessage(
          `✅ Email <b>${text}</b> сохранён! Теперь ты будешь получать уведомления.`,
          false,
          true,
        );
        isWaiting = false;
        sendBtn.disabled = false;
        messageInput.disabled = false;
        messageInput.value = "";
        return;
      }

      showTyping();
      const reply = await sendToAPI(text);
      removeTyping();
      addMessage(reply, false, true);
      chatHistory.push({ role: "assistant", content: reply });

      isWaiting = false;
      sendBtn.disabled = false;
      messageInput.disabled = false;
      messageInput.value = "";
      messageInput.focus();
      autoResizeInput();
    });
  }

  function autoResizeInput() {
    if (!messageInput) return;
    messageInput.style.height = "auto";
    messageInput.style.height = Math.min(messageInput.scrollHeight, 120) + "px";
  }

  if (messageInput) {
    messageInput.addEventListener("input", autoResizeInput);
    messageInput.addEventListener("keydown", function(e) {
      if (e.key === "Enter" && !e.shiftKey) {
        e.preventDefault();
        chatFormEl.dispatchEvent(new Event("submit"));
      }
    });
  }

  // === ИНИЦИАЛИЗАЦИЯ ===
  captureReferral();

  // v5.0: Если пользователь уже ввёл email на /join/ — пропускаем
  // экраны email и каналов, сразу показываем обучение/чат
  (function checkExistingUser() {
    try {
      const emailSubmitted = localStorage.getItem("neurogen_email_submitted");
      const existingEmail = localStorage.getItem("neurogen_email");

      if (emailSubmitted === "true" && existingEmail) {
        // Email уже сохранён с /join/ → пропускаем ввод
        userEmail = existingEmail;

        // Пропускаем экраны email и каналов → сразу к обучению
        const emailScreen = document.getElementById("screenEmail");
        const channelsScreen = document.getElementById("screenChannels");
        if (emailScreen) emailScreen.classList.remove("active");
        if (channelsScreen) channelsScreen.classList.remove("active");

        // Запускаем обучение/чат
        startTraining();
        console.log("[AI] Returning user, skipping to training", {
          email: userEmail,
          ref: referrer,
        });
      }
    } catch (e) {
      console.warn("[AI] checkExistingUser error", e);
    }
  })();
})();
    </script>
  </body>
</html>
