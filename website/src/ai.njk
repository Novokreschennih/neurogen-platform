---
title: "NeuroGen AI — Твой ИИ-архитектор"
permalink: /ai/
eleventyExcludeFromCollections: true

---
<!DOCTYPE html>
<html lang="ru" class="scroll-smooth">
  <head>
    <meta charset="UTF-8">
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    >
    <title>{{ title }}</title>
    <meta
      name="description"
      content="NeuroGen AI — твой персональный ИИ-архитектор для построения бизнес-стратегий и автоворонок."
    >
    <meta name="robots" content="noindex, nofollow">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
@keyframes blob {
  0% {
    transform: translate(0px, 0px) scale(1);
  }
  33% {
    transform: translate(30px, -50px) scale(1.1);
  }
  66% {
    transform: translate(-20px, 20px) scale(0.9);
  }
  100% {
    transform: translate(0px, 0px) scale(1);
  }
}
.animate-blob {
  animation: blob 7s infinite;
}
.animation-delay-2000 {
  animation-delay: 2s;
}
.animation-delay-4000 {
  animation-delay: 4s;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(16px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
.msg-animate {
  animation: fadeInUp 0.4s ease-out both;
}

@keyframes bounce {
  0%,
  80%,
  100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}
.typing-dot {
  animation: bounce 1.4s infinite ease-in-out both;
}
.typing-dot:nth-child(1) {
  animation-delay: -0.32s;
}
.typing-dot:nth-child(2) {
  animation-delay: -0.16s;
}

/* Скрытый скроллбар */
.chat-scroll::-webkit-scrollbar {
  width: 0;
  height: 0;
}
.chat-scroll {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

body {
  background-color: #050505;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  overflow: hidden;
}

</style>
  </head>
  <body class="h-screen w-screen flex flex-col relative">
    <!-- Фоновые градиентные пятна -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none -z-10">
      <div class="absolute top-[-10%] left-[-10%] w-96 h-96 bg-purple-600 rounded-full mix-blend-screen filter blur-[128px] opacity-[0.15] animate-blob">
      </div>
      <div class="absolute bottom-[-10%] right-[-10%] w-96 h-96 bg-cyan-600 rounded-full mix-blend-screen filter blur-[128px] opacity-[0.15] animate-blob animation-delay-2000">
      </div>
      <div class="absolute top-[40%] left-[60%] w-72 h-72 bg-purple-500 rounded-full mix-blend-screen filter blur-[96px] opacity-[0.08] animate-blob animation-delay-4000">
      </div>
    </div>

    <!-- HEADER -->
    <header class="flex items-center justify-between px-5 py-3 border-b border-white/5 bg-[#050505]/60 backdrop-blur-md z-10 shrink-0">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-cyan-500 to-purple-600 flex items-center justify-center text-sm font-bold shadow-lg shadow-purple-500/20">
          N
        </div>
        <div>
          <div class="text-sm font-bold tracking-wide">NeuroGen AI</div>
          <div class="flex items-center gap-1.5 text-[11px] text-gray-400">
            <span
              class="inline-block w-2 h-2 rounded-full bg-green-400 animate-pulse"
            ></span>
            Online
          </div>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <a
          href="/blog/"
          class="text-xs text-gray-500 hover:text-gray-300 transition-colors px-3 py-1.5 rounded-lg hover:bg-white/5"
        >
          Блог
        </a>
        <a
          href="/join/"
          class="text-xs text-gray-500 hover:text-gray-300 transition-colors px-3 py-1.5 rounded-lg hover:bg-white/5"
        >
          Присоединиться
        </a>
      </div>
    </header>

    <!-- CHAT AREA -->
    <main
      id="chatArea"
      class="flex-1 overflow-y-auto chat-scroll px-4 py-6 flex flex-col gap-4"
    >
      <!-- Сообщения будут добавляться сюда динамически -->
    </main>

    <!-- INPUT AREA -->
    <div class="border-t border-white/5 bg-[#050505]/40 backdrop-blur-xl px-4 py-3 shrink-0 z-10">
      <form id="chatForm" class="flex items-end gap-3 max-w-3xl mx-auto">
        <div class="flex-1 relative">
          <textarea
            id="messageInput"
            rows="1"
            placeholder="Напиши сообщение..."
            class="w-full resize-none rounded-2xl bg-white/5 backdrop-blur-md border border-white/10 text-white placeholder-gray-500 px-5 py-3.5 pr-12 text-sm leading-relaxed focus:outline-none focus:border-purple-500/50 focus:ring-1 focus:ring-purple-500/30 transition-all"
          ></textarea>
          <button
            type="submit"
            id="sendBtn"
            class="absolute right-2 bottom-2 w-9 h-9 rounded-xl bg-gradient-to-r from-cyan-500 to-purple-500 flex items-center justify-center hover:opacity-90 active:scale-95 transition-all disabled:opacity-30 disabled:cursor-not-allowed"
          >
            <svg
              class="w-4 h-4 text-white"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="22" y1="2" x2="11" y2="13"></line>
              <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
          </button>
        </div>
      </form>
      <div class="text-center mt-2 text-[10px] text-gray-600">
        NeuroGen AI может допускать неточности. Проверяйте важную информацию.
      </div>
    </div>

    <script>
    (function() {
  "use strict";

  // === КОНФИГУРАЦИЯ ===
  const API_URL =
    "https://d5dsbah1d4ju0glmp9d0.3zvepvee.apigw.yandexcloud.net/?action=web-chat";

  // === СОСТОЯНИЕ ===
  let referrer = "";
  let chatHistory = [];
  let isWaiting = false;

  // === DOM-ЭЛЕМЕНТЫ ===
  const chatArea = document.getElementById("chatArea");
  const chatForm = document.getElementById("chatForm");
  const messageInput = document.getElementById("messageInput");
  const sendBtn = document.getElementById("sendBtn");

  // === 1. ПЕРЕХВАТ РЕФЕРАЛА ===
  function captureReferral() {
    const params = new URLSearchParams(window.location.search);
    const ref = params.get("ref");
    if (ref) {
      referrer = ref;
      try {
        localStorage.setItem("neurogen_ref", ref);
      } catch (e) {}
    } else {
      try {
        referrer = localStorage.getItem("neurogen_ref") || "";
      } catch (e) {}
    }
  }

  // === 2. РЕНДЕРИНГ СООБЩЕНИЙ ===
  function createMessageBubble(text, isUser, isHTML) {
    const wrapper = document.createElement("div");
    wrapper.className = "flex w-full msg-animate";
    wrapper.classList.add(isUser ? "justify-end" : "justify-start");

    const bubble = document.createElement("div");
    bubble.className =
      "max-w-[85%] md:max-w-[70%] rounded-2xl px-4 py-3 text-sm leading-relaxed break-words";

    if (isUser) {
      bubble.classList.add(
        "bg-gradient-to-r",
        "from-cyan-500",
        "to-purple-500",
        "text-white",
        "rounded-br-md",
      );
      bubble.textContent = text;
    } else {
      bubble.classList.add("bg-gray-800/80", "text-gray-100", "rounded-bl-md");
      if (isHTML) {
        bubble.innerHTML = text;
      } else {
        bubble.textContent = text;
      }
    }

    wrapper.appendChild(bubble);
    return wrapper;
  }

  function createTypingIndicator() {
    const wrapper = document.createElement("div");
    wrapper.className = "flex w-full justify-start msg-animate";
    wrapper.id = "typingIndicator";

    const bubble = document.createElement("div");
    bubble.className =
      "bg-gray-800/80 rounded-2xl rounded-bl-md px-5 py-4 flex items-center gap-1.5";

    for (let i = 0; i < 3; i++) {
      const dot = document.createElement("span");
      dot.className =
        "typing-dot w-2 h-2 bg-gray-400 rounded-full inline-block";
      bubble.appendChild(dot);
    }

    wrapper.appendChild(bubble);
    return wrapper;
  }

  function addMessage(text, isUser, isHTML) {
    const el = createMessageBubble(text, isUser, isHTML);
    chatArea.appendChild(el);
    scrollToBottom();
  }

  function showTyping() {
    removeTyping();
    const el = createTypingIndicator();
    chatArea.appendChild(el);
    scrollToBottom();
  }

  function removeTyping() {
    const existing = document.getElementById("typingIndicator");
    if (existing) existing.remove();
  }

  function scrollToBottom() {
    requestAnimationFrame(() => {
      chatArea.scrollTop = chatArea.scrollHeight;
    });
  }

  // === 3. ПРИВЕТСТВЕННОЕ СООБЩЕНИЕ ===
  function showWelcome() {
    setTimeout(() => {
      const welcomeText =
        "Привет! Я — <b>NeuroGen</b>, твой ИИ-архитектор. Я могу собрать для тебя бизнес-стратегию и автоворонку прямо сейчас.<br><br>В какой нише ты работаешь?";
      addMessage(welcomeText, false, true);
    }, 1000);
  }

  // === 4. EMAIL-ПЕРЕХВАТЧИК ===
  const EMAIL_REGEX = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function isEmail(text) {
    return EMAIL_REGEX.test(text.trim());
  }

  function handleEmailCapture(email) {
    // Отправляем на бэкенд флаг email
    fetch(API_URL, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        isEmail: true,
        email: email.trim(),
        referrer: referrer,
      }),
    }).catch(() => {
      // Даже если запрос не прошёл — показываем ответ
    });

    const responseText =
      `Бинго! 🎯 Твой аккаунт создан. Я отправил доступ на почту <b>${email}</b>.<br><br>А пока — нажми кнопку ниже, чтобы войти в систему!`;
    addMessage(responseText, false, true);

    // Кнопка перехода
    setTimeout(() => {
      const wrapper = document.createElement("div");
      wrapper.className = "flex w-full justify-start msg-animate";

      const btnContainer = document.createElement("div");
      btnContainer.className =
        "bg-gray-800/80 rounded-2xl rounded-bl-md px-4 py-3";

      const link = document.createElement("a");
      link.href = "https://t.me/sethubble_biz_bot";
      link.target = "_blank";
      link.rel = "noopener noreferrer";
      link.className =
        "inline-flex items-center justify-center px-6 py-3 rounded-xl bg-gradient-to-r from-cyan-500 to-purple-500 text-white text-sm font-bold hover:opacity-90 active:scale-95 transition-all shadow-lg shadow-purple-500/20";
      link.innerHTML = "🚀 Войти в систему";

      btnContainer.appendChild(link);
      wrapper.appendChild(btnContainer);
      chatArea.appendChild(wrapper);
      scrollToBottom();
    }, 400);
  }

  // === 5. ОТПРАВКА ЗАПРОСА К API ===
  async function sendToAPI(userMessage) {
    try {
      const response = await fetch(API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          message: userMessage,
          referrer: referrer,
          history: chatHistory.slice(-20), // Последние 20 сообщений для контекста
        }),
      });

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
      }

      const data = await response.json();
      // Ожидаем поле answer или message в ответе
      return data.answer || data.message || data.response || data.text
        || "Извини, не удалось получить ответ. Попробуй ещё раз.";
    } catch (error) {
      console.error("API Error:", error);
      return "⚠️ Сейчас я немного занят — мой сервер думает над твоим вопросом. Попробуй через пару секунд!";
    }
  }

  // === 6. ОБРАБОТКА ОТПРАВКИ ===
  async function handleSubmit(userText) {
    const text = userText.trim();
    if (!text || isWaiting) return;

    // Блокируем ввод
    isWaiting = true;
    sendBtn.disabled = true;
    messageInput.disabled = true;

    // Добавляем сообщение пользователя
    addMessage(text, true);
    chatHistory.push({ role: "user", content: text });

    // Проверяем email
    if (isEmail(text)) {
      handleEmailCapture(text);
      isWaiting = false;
      sendBtn.disabled = false;
      messageInput.disabled = false;
      messageInput.value = "";
      messageInput.focus();
      return;
    }

    // Показываем индикатор печатания
    showTyping();

    // Запрос к API
    const reply = await sendToAPI(text);

    // Убираем индикатор, добавляем ответ
    removeTyping();
    addMessage(reply, false, true);
    chatHistory.push({ role: "assistant", content: reply });

    // Разблокируем ввод
    isWaiting = false;
    sendBtn.disabled = false;
    messageInput.disabled = false;
    messageInput.value = "";
    messageInput.focus();
    autoResizeInput();
  }

  // === 7. АВТО-РАЗМЕР TEXTAREA ===
  function autoResizeInput() {
    messageInput.style.height = "auto";
    messageInput.style.height = Math.min(messageInput.scrollHeight, 120) + "px";
  }

  // === ИНИЦИАЛИЗАЦИЯ ===
  captureReferral();
  showWelcome();

  chatForm.addEventListener("submit", function(e) {
    e.preventDefault();
    const text = messageInput.value;
    if (text.trim()) {
      handleSubmit(text);
    }
  });

  messageInput.addEventListener("input", autoResizeInput);

  // Отправка по Enter (Shift+Enter — новая строка)
  messageInput.addEventListener("keydown", function(e) {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      chatForm.dispatchEvent(new Event("submit"));
    }
  });

  messageInput.focus();
})();
    </script>
  </body>
</html>
