<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | Академия SetHubble</title>
    <meta name="description" content="Урок из Академии SetHubble">
    <meta name="robots" content="noindex, nofollow">

    <link rel="stylesheet" href="/css/fonts.css" />
    <link rel="stylesheet" href="/css/index.css">
  </head>
  <body>
    <div class="academy-container">
      <article class="academy-content">
        <header class="academy-header">
          <span class="academy-badge">Академия SetHubble</span>
          <h1>{{ title }}</h1>
        </header>

        {{ content | safe }}
      </article>

      {# --- БЛОК ДЛЯ СЕКРЕТНОГО СЛОВА --- #}
      <section class="secret-word-block">
        <div class="secret-content">
          <h2>Задание выполнено?</h2>
          <p>{{ secret_instruction }}</p>

          <div class="secret-word-box">
            <span class="label">ТВОЙ КОД ДОСТУПА:</span>
            <span class="word">{{ secret_word }}</span>
          </div>

          {# Кнопка с динамической ссылкой #}
          <a
            href="https://t.me/sethubble_biz_bot"
            id="tg-return-btn"
            target="_blank"
            class="cta-button js-bot-link"
          >
            Вернуться в Telegram
          </a>
        </div>
      </section>
    </div>

    {# --- СКРИПТ ПЕРЕХВАТА БОТА --- #}
    <script>
    document.addEventListener("DOMContentLoaded", function() {
  // Читаем параметры из URL (например: ?bot=Anton_Partner_Bot)
  const urlParams = new URLSearchParams(window.location.search);
  const botUsername = urlParams.get("bot");
  const vkGroup = urlParams.get("vk_group");
  const isWeb = urlParams.get("web");
  
  const btn = document.getElementById("tg-return-btn");
  
  if (btn) {
    if (isWeb) {
      // Если открыто из Web-чата
      btn.innerHTML = "💬 Вернуться в Чат";
      // Обычно статьи открываются в новой вкладке, поэтому закрываем её
      btn.href = "javascript:window.close();"; 
    } else if (vkGroup) {
      // Если открыто из VK
      btn.innerHTML = "💬 Вернуться ВКонтакте";
      btn.href = `https://vk.me/club${vkGroup}`;
    } else if (botUsername) {
      // Если открыто из Telegram
      const cleanName = botUsername.replace("@", "");
      btn.innerHTML = "✈ Вернуться в Telegram";
      btn.href = `https://t.me/${cleanName}`;
    }
  }
});
    </script>

    {# --- ЛОКАЛЬНЫЕ СТИЛИ ДЛЯ АКАДЕМИИ (CYBERPUNK STYLE) --- #}
    <style>
/* ИЗОЛЯЦИЯ ВОРОНКИ: СКРЫВАЕМ ШАПКУ И ФУТЕР */
body > header,
body > footer,
.nav,
.breadcrumbs,
.reading-progress,
.back-to-top,
.related-posts,
.telegram-subscribe,
.cta-block,
.links-nextprev,
.container > header,
.container > footer {
  display: none !important;
}

/* Убираем лишний отступ сверху */
.container {
  padding-top: 40px !important;
}

/* Базовая верстка */
.academy-container {
  max-width: 800px;
  margin: 0 auto;
  padding: 60px 20px 100px;
}
.academy-content {
  font-size: 1.1rem;
  line-height: 1.8;
  color: var(--text-gray);
}
.academy-header {
  text-align: center;
  margin-bottom: 50px;
}
.academy-badge {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(139, 92, 246, 0.2));
  color: var(--primary);
  padding: 8px 20px;
  border-radius: 50px;
  font-weight: 700;
  text-transform: uppercase;
  font-size: 0.85rem;
  display: inline-block;
  margin-bottom: 20px;
  letter-spacing: 0.1em;
  border: 1px solid rgba(99, 102, 241, 0.4);
}
.academy-header h1 {
  font-size: clamp(2rem, 4vw, 2.8rem);
  margin-bottom: 20px;
  color: var(--text-light);
}
.academy-content h2 {
  font-size: 1.8rem;
  color: var(--text-light);
  margin-top: 50px;
  margin-bottom: 20px;
}
.academy-content h3 {
  font-size: 1.4rem;
  color: var(--text-light);
  margin-top: 40px;
  margin-bottom: 15px;
}
.academy-content p {
  margin-bottom: 25px;
}
.academy-content strong {
  color: var(--text-light);
  font-weight: 700;
}
.academy-content ul,
.academy-content ol {
  margin-bottom: 25px;
  padding-left: 25px;
}
.academy-content li {
  margin-bottom: 12px;
}

/* Выделение кодового слова в тексте */
.secret-word-highlight {
  color: var(--neon);
  font-weight: 700;
  text-shadow: 0 0 10px rgba(0, 247, 255, 0.3);
  border-bottom: 2px solid rgba(0, 247, 255, 0.4);
  padding: 2px 6px;
  border-radius: 4px;
  background: rgba(0, 247, 255, 0.05);
}

/* Блок секретного слова */
.secret-word-block {
  background: rgba(0, 247, 255, 0.03);
  border: 1px solid rgba(0, 247, 255, 0.2);
  padding: 60px 20px;
  border-radius: 32px;
  text-align: center;
  margin: 80px auto;
  max-width: 700px;
  position: relative;
  overflow: hidden;
  box-shadow:
    0 20px 50px rgba(0, 0, 0, 0.3),
    inset 0 0 30px rgba(0, 247, 255, 0.05);
}

/* Эффект свечения сверху */
.secret-word-block::before {
  content: "";
  position: absolute;
  top: -100px;
  left: 50%;
  transform: translateX(-50%);
  width: 300px;
  height: 300px;
  background: radial-gradient(circle, rgba(0, 247, 255, 0.2), transparent 70%);
  pointer-events: none;
  z-index: 1;
  animation: pulse 3s ease-in-out infinite;
}
@keyframes pulse {
  0%,
  100% {
    opacity: 0.5;
  }
  50% {
    opacity: 0.8;
  }
}

.secret-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.secret-word-block h2 {
  color: var(--text-light);
  font-size: 2.2rem;
  margin-bottom: 15px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.secret-word-block p {
  color: var(--text-gray);
  font-size: 1.15rem;
  max-width: 500px;
  margin: 0 auto 35px;
  line-height: 1.6;
}

/* Ящик с секретным словом */
.secret-word-box {
  display: inline-flex;
  flex-direction: column;
  background: var(--bg-deep);
  border: 1px solid var(--glass-border);
  padding: 20px 50px;
  border-radius: 16px;
  margin-bottom: 50px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  position: relative;
}
.secret-word-box::after {
  content: "";
  position: absolute;
  inset: -1px;
  background: linear-gradient(90deg, transparent, rgba(0, 247, 255, 0.3), transparent);
  border-radius: 16px;
  pointer-events: none;
}

.secret-word-box .label {
  font-size: 0.85rem;
  color: var(--text-muted);
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  font-weight: 500;
}
.secret-word-box .word {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--neon);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  text-shadow: 0 0 15px rgba(0, 247, 255, 0.4);
}

/* ========================================================= */
/* 🔥 ТА САМАЯ КНОПКА ВОЗВРАТА (New Cyberpunk Style) 🔥 */
/* ========================================================= */
#tg-return-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: var(--neon);
  border: 2px solid var(--neon);
  padding: 20px 45px;
  font-size: 1.1rem;
  font-weight: 800;
  text-transform: uppercase;
  text-decoration: none;
  letter-spacing: 0.15em;
  border-radius: 50px;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
  position: relative;
  overflow: hidden;
  box-shadow:
    0 0 15px rgba(0, 247, 255, 0.3),
    inset 0 0 10px rgba(0, 247, 255, 0.2);
  margin-top: 10px;
}

/* Иконка Telegram (добавляем псевдоэлементом) */
#tg-return-btn::before {
  content: "✈";
  margin-right: 12px;
  font-size: 1.3rem;
  transition: transform 0.3s ease;
}

/* Эффект блика при наведении */
#tg-return-btn::after {
  content: "";
  position: absolute;
  top: -50%;
  left: -100%;
  width: 100%;
  height: 200%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transform: rotate(25deg);
  transition: left 0.5s;
}

/* Эффекты при наведении (Hover) */
#tg-return-btn:hover {
  color: var(--bg-deep);
  background-color: var(--neon);
  box-shadow:
    0 0 40px var(--neon-glow),
    0 0 10px var(--neon);
  transform: translateY(-3px);
}

#tg-return-btn:hover::before {
  transform: translateX(3px) rotate(-10deg);
}

#tg-return-btn:hover::after {
  left: 100%;
}

/* Адаптив для мобильных */
@media (max-width: 600px) {
  .academy-container {
    padding: 40px 15px 80px;
  }
  .secret-word-block {
    padding: 40px 15px;
    border-radius: 24px;
    margin: 50px auto;
  }
  .secret-word-block h2 {
    font-size: 1.8rem;
  }
  .secret-word-box {
    padding: 15px 30px;
  }
  .secret-word-box .word {
    font-size: 2rem;
  }
  #tg-return-btn {
    width: 100%;
    padding: 18px 20px;
    font-size: 1rem;
  }
}

</style>
  </body>
</html>
