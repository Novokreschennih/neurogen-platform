<!doctype html>
<html lang="{{ metadata.language }}">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ title or metadata.title }}</title>
		<meta name="description" content="{{ description or metadata.description }}">

		<!-- Canonical URL -->
		<link rel="canonical" href="{{ metadata.url }}{{ page.url }}">

		<!-- Preload critical resources -->
		<link rel="preload" href="/css/index.css" as="style">
		<link rel="preload" href="/css/fonts.css" as="style">

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="{{ 'article' if tags else 'website' }}">
		<meta property="og:url" content="{{ metadata.url }}{{ page.url }}">
		<meta property="og:title" content="{{ title or metadata.title }}">
		<meta property="og:description" content="{{ description or metadata.description }}">
		<meta property="og:image" content="{{ image or metadata.url + '/public/og-image.png' }}">

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image">
		<meta name="twitter:url" content="{{ metadata.url }}{{ page.url }}">
		<meta name="twitter:title" content="{{ title or metadata.title }}">
		<meta name="twitter:description" content="{{ description or metadata.description }}">
		<meta name="twitter:image" content="{{ image or metadata.url + '/public/og-image.png' }}">

		<script>
			(function () {
				const theme = localStorage.getItem("theme");
				if (theme === "light") {
					document.documentElement.classList.add("light-theme");
				} else if (theme === "dark") {
					document.documentElement.classList.remove("light-theme");
				} else if (window.matchMedia("(prefers-color-scheme: light)").matches) {
					document.documentElement.classList.add("light-theme");
				}
			})();
		</script>

		<link rel="icon" href="{{ '/favicon.svg' | url }}" type="image/svg+xml">
		<link rel="alternate" type="application/rss+xml" title="RSS Feed" href="{{ metadata.url }}/feed/feed.xml">
		<link rel="alternate" type="application/atom+xml" title="News RSS" href="{{ metadata.url }}/feed/news.xml">
		<link rel="manifest" href="/manifest.json">
		<meta name="theme-color" content="#6366f1">
		<meta name="apple-mobile-web-app-capable" content="yes">
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
		<meta name="apple-mobile-web-app-title" content="SetHubble">
		<link type="application/rss+xml" rel="alternate" href="https://sethubble.ru/feed/feed.xml" title="Блог о SetHubble">
		<link rel="stylesheet" href="/css/index.css">
		<link rel="stylesheet" href="/css/fonts.css" />

		<script type="module">{% include "node_modules/@zachleat/heading-anchors/heading-anchors.js" %}</script>
	</head>
	<body>
		<a href="#main" id="skip-link" class="visually-hidden">Skip to main content</a>

		<!-- Прогресс чтения -->
		<div class="reading-progress" id="readingProgress" aria-hidden="true"></div>

		<div class="container">
			<div class="main-box">

				<header>
					<a href="/blog/" class="home-link">
						<span class="home-link-line1">Блог о</span>
						<span class="home-link-line2">SetHubble</span>
					</a>

					<nav>
						<h2 class="visually-hidden">Top level navigation menu</h2>
						<ul class="nav">
							<li class="nav-item"><a href="/blog/" aria-current="page"{% if page.url != '/blog/' %} style="opacity:0.7"{% endif %}>Блог</a></li>
							<li class="nav-item"><a href="/calculator/">Калькулятор</a></li>
							<li class="nav-item"><a href="/news/">Новости</a></li>
							<li class="nav-item"><a href="/archive/">Статьи</a></li>
							<li class="nav-item">
								<a href="/search/" aria-label="Поиск" class="search-icon">
									<svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"/></svg>
								</a>
							</li>
						</ul>
					</nav>

					<div class="header-actions">
						<button id="theme-toggle" class="theme-toggle" aria-label="Переключить тему">
							<svg class="sun-icon" viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0 .39-.39.39-1.03 0-1.41l-1.06-1.06zm1.06-10.96c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zM7.05 18.36c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z"/></svg>
							<svg class="moon-icon" viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-.46-.04-.92-.1-1.36-.98 1.37-2.58 2.26-4.4 2.26-2.98 0-5.4-2.42-5.4-5.4 0-1.81.89-3.42 2.26-4.4-.44-.06-.9-.1-1.36-.1z"/></svg>
						</button>
						<a href="/" class="back-to-site">На главную →</a>
					</div>
				</header>

				<main id="main">
					<heading-anchors>
						{{ content | safe }}
					</heading-anchors>
				</main>

				<footer>
					<!-- ИСПРАВЛЕНО: Новый CTA для блога -->
					<div class="footer-cta" style="text-align: center; padding: 40px 20px; background: rgba(255,255,255,0.05); border-radius: 16px; margin-bottom: 40px; border: 1px solid rgba(255,255,255,0.1);">
						<h2 style="font-size: 28px; margin-bottom: 16px; color: var(--text-color);">Готовы запустить свой IT-бизнес?</h2>
						<p style="color: var(--text-gray); max-width: 600px; margin: 0 auto 24px; font-size: 16px; line-height: 1.5;">
							Настройте мультиканального ИИ-бота за 1 минуту. Оцифруйте сарафанное радио и начните получать пассивный доход.
						</p>
						<button class="js-open-modal cta-button" style="background: linear-gradient(to right, #06b6d4, #9333ea); color: white; border: none; padding: 16px 32px; border-radius: 12px; font-weight: bold; font-size: 18px; cursor: pointer; transition: opacity 0.2s;">🚀 ПОЛУЧИТЬ СИСТЕМУ БЕСПЛАТНО</button>
					</div>
				
					<div class="footer-meta">
						<a href="{{ '/tags/' | url }}">Посмотреть все теги</a>						
					</div>
				</footer>
			
			</div>
		</div>

		<script src="/js/main.js" defer></script>
		<script src="/js/y-metrika.js" defer></script>

		<!-- Регистрация Service Worker -->
		<script>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/js/sw.js')
						.then((reg) => console.log('SW registered:', reg.scope))
						.catch((err) => console.log('SW registration failed:', err));
				});
			}
		</script>

		<!-- Кнопка "Наверх" -->
		<a href="#main" class="back-to-top" id="backToTop" aria-label="Наверх">
			<svg viewBox="0 0 24 24"><path d="M12 4l-8 8h6v8h4v-8h6z"/></svg>
		</a>

		<!-- ========================================== -->
		<!-- МОДАЛЬНОЕ ОКНО ВОРОНКИ (Встроено в Блог)   -->
		<!-- ========================================== -->
		<div id="leadModal" class="hidden" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999; align-items: center; justify-content: center; background: rgba(0,0,0,0.8); backdrop-filter: blur(4px); opacity: 0; transition: opacity 0.3s ease;">
			<div id="modalContent" style="width: 100%; max-width: 400px; background: #0a0a0a; border: 1px solid rgba(255,255,255,0.1); border-radius: 24px; padding: 24px; position: relative; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); transform: translateY(20px); transition: transform 0.3s ease; margin: 0 16px;">
				<button id="closeModal" style="position: absolute; top: 16px; right: 16px; background: none; border: none; cursor: pointer; color: #666; padding: 4px;">
					<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="24" height="24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
				</button>

				<!-- ШАГ 1: Сбор Email -->
				<div id="stepEmail">
					<div style="text-align: center; margin-bottom: 24px;">
						<div style="width: 64px; height: 64px; background: linear-gradient(to bottom right, #06b6d4, #9333ea); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; margin: 0 auto 16px;">📧</div>
						<h3 style="font-size: 24px; font-weight: bold; color: white; margin: 0 0 8px 0;">Куда отправить доступы?</h3>
						<p style="font-size: 14px; color: #888; margin: 0;">Мы пришлем резервную ссылку на твою систему и обучающие материалы.</p>
					</div>

					<form id="emailForm" style="display: flex; flex-direction: column; gap: 16px; margin: 0;">
						<div>
							<input type="email" id="userEmail" required placeholder="твой@email.com" style="width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 12px 16px; color: white; font-size: 16px; text-align: center; box-sizing: border-box; outline: none;">
						</div>
						<button type="submit" id="submitEmailBtn" style="width: 100%; background: linear-gradient(to right, #06b6d4, #9333ea); color: white; font-weight: bold; padding: 14px; border-radius: 12px; cursor: pointer; border: none; font-size: 16px;">
							ПРОДОЛЖИТЬ
						</button>
						<p id="emailError" style="color: #f87171; font-size: 12px; text-align: center; display: none; margin: 0;">Пожалуйста, введи корректный email</p>
					</form>
					<p style="font-size: 10px; color: #666; text-align: center; margin-top: 16px;">Нажимая кнопку, ты соглашаешься с политикой конфиденциальности.</p>
				</div>

				<!-- ШАГ 2: Выбор платформы -->
				<div id="stepChoice" style="display: none;">
					<div style="text-align: center; margin-bottom: 24px;">
						<div style="width: 64px; height: 64px; background: linear-gradient(to bottom right, #4ade80, #3b82f6); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; margin: 0 auto 16px;">✅</div>
						<h3 style="font-size: 24px; font-weight: bold; color: white; margin: 0 0 8px 0;">Отлично!</h3>
						<p style="font-size: 14px; color: #888; margin: 0;">Где тебе удобнее пройти настройку?</p>
					</div>

					<div style="display: flex; flex-direction: column; gap: 12px;">
						<!-- Telegram -->
						<button id="btnTelegram" style="width: 100%; background: rgba(42, 171, 238, 0.1); border: 1px solid rgba(42, 171, 238, 0.3); border-radius: 12px; padding: 16px; text-align: left; display: flex; align-items: center; gap: 16px; cursor: pointer;">
							<div style="font-size: 24px;">✈️</div>
							<div>
								<div style="font-weight: bold; color: white; font-size: 16px; margin-bottom: 4px;">Через Telegram-бота</div>
								<div style="font-size: 12px; color: #888;">Быстро, удобно, всё в мессенджере</div>
							</div>
						</button>

						<!-- VK -->
						<button id="btnVK" style="width: 100%; background: rgba(0, 119, 255, 0.1); border: 1px solid rgba(0, 119, 255, 0.3); border-radius: 12px; padding: 16px; text-align: left; display: flex; align-items: center; gap: 16px; cursor: pointer;">
							<div style="font-size: 24px;">💬</div>
							<div>
								<div style="font-weight: bold; color: white; font-size: 16px; margin-bottom: 4px;">Через ВКонтакте</div>
								<div style="font-size: 12px; color: #888;">Не заблокирован, аудитория 80M+ в РФ</div>
							</div>
						</button>

						<!-- Web -->
						<button id="btnWeb" style="width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 16px; text-align: left; display: flex; align-items: center; gap: 16px; cursor: pointer;">
							<div style="font-size: 24px;">🌐</div>
							<div>
								<div style="font-weight: bold; color: white; font-size: 16px; margin-bottom: 4px;">Через Web-сайт</div>
								<div style="font-size: 12px; color: #888;">Работает в любом браузере, без VPN</div>
							</div>
						</button>

						<!-- Email -->
						<button id="btnEmail" style="width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 16px; text-align: left; display: flex; align-items: center; gap: 16px; cursor: pointer;">
							<div style="font-size: 24px;">📧</div>
							<div>
								<div style="font-weight: bold; color: white; font-size: 16px; margin-bottom: 4px;">Email-рассылка</div>
								<div style="font-size: 12px; color: #888;">Пошаговая настройка через email</div>
							</div>
						</button>
					</div>
				</div>

				<!-- ШАГ 3: Email отправлен -->
				<div id="email-submitted" style="display: none;">
					<div style="text-align: center;">
						<div style="width: 64px; height: 64px; background: linear-gradient(to bottom right, #4ade80, #10b981); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; margin: 0 auto 16px;">📤</div>
						<h3 style="font-size: 24px; font-weight: bold; color: white; margin: 0 0 8px 0;">Проверь почту!</h3>
						<p style="font-size: 14px; color: #888; margin: 0 0 16px 0;">Мы отправили ссылку на <br><span id="email-submitted-msg" style="color: #06b6d4; font-weight: bold;"></span></p>
						<p style="font-size: 12px; color: #666; margin: 0;">Если письмо не пришло — проверь папку "Спам"</p>
					</div>
				</div>

				<!-- ШАГ 4: С возвращением! -->
				<div id="stepRemembered" style="display: none;">
					<div style="text-align: center;">
						<div style="width: 80px; height: 80px; background: linear-gradient(to bottom right, #a855f7, #ec4899); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 30px; margin: 0 auto 16px;">👋</div>
						<h3 style="font-size: 24px; font-weight: bold; color: white; margin: 0 0 8px 0;">С возвращением!</h3>
						<p style="font-size: 14px; color: #888; margin: 0 0 8px 0;">Я вспомнил тебя</p>
						<p id="remembered-email-msg" style="font-size: 18px; font-weight: 600; color: #c084fc; margin: 0 0 24px 0;"></p>
						<button id="btnProceedToChannels" style="width: 100%; background: linear-gradient(to right, #06b6d4, #9333ea); color: white; font-weight: bold; padding: 14px; border-radius: 12px; cursor: pointer; border: none; font-size: 16px;">
							Выбрать канал для настройки →
						</button>
					</div>
				</div>
			</div>
		</div>

		<noscript><div><img src="https://mc.yandex.ru/watch/104313731" style="position:absolute; left:-9999px;" alt="" /></div></noscript>

		<!-- ========================================== -->
		<!-- ГЛОБАЛЬНЫЙ СКРИПТ ВОРОНКИ И МОДАЛКИ        -->
		<!-- ========================================== -->
		<script>
			document.addEventListener("DOMContentLoaded", () => {
				const DEFAULT_BOT = "sethubble_biz_bot";
				const DEFAULT_PARTNER_ID = "p_qdr";
				const API_URL = "https://d5dsbah1d4ju0glmp9d0.3zvepvee.apigw.yandexcloud.net/?action=web-chat";
				const WEB_CHAT_URL = "/ai/";
				const VK_COMMUNITY_URL = "https://vk.me/club237421168";

				let partnerId = null;
				let refBot = null;
				let currentSessionId = localStorage.getItem("neurogen_web_session");

				if (!currentSessionId) {
					currentSessionId = `web_${Math.random().toString(36).substring(2, 15)}_${Date.now()}`;
					localStorage.setItem("neurogen_web_session", currentSessionId);
				}

				const urlParams = new URLSearchParams(window.location.search);
				let encodedId = urlParams.get("page");

				const fromHex = (hex) => {
					try {
						if (!/^[0-9a-fA-F]+$/.test(hex)) return null;
						if (hex.length % 2 !== 0) return null;
						let str = "";
						for (let i = 0; i < hex.length; i += 2) {
							str += String.fromCharCode(parseInt(hex.substr(i, 2), 16));
						}
						return str;
					} catch (e) { return null; }
				};

				if (encodedId) {
					const decoded = fromHex(encodedId);
					partnerId = (decoded && decoded.length > 1) ? decoded.trim() : encodedId.trim();
					if (partnerId) localStorage.setItem("neurogen_partner_id", partnerId);
				}

				if (!partnerId) {
					partnerId = localStorage.getItem("neurogen_partner_id") || DEFAULT_PARTNER_ID;
				}

				const storedBot = localStorage.getItem("neurogen_partner_bot");
				refBot = (storedBot && storedBot !== "sethubble_bot") ? storedBot : DEFAULT_BOT;

				const urlStep = urlParams.get("step");
				const storedEmail = localStorage.getItem("neurogen_email");
				const emailVerified = localStorage.getItem("neurogen_email_verified") === "true";

				// Управление модальным окном
				const modal = document.getElementById("leadModal");
				const modalContent = document.getElementById("modalContent");
				const btnOpenList = document.querySelectorAll(".js-open-modal");
				const btnClose = document.getElementById("closeModal");

				const stepEmail = document.getElementById("stepEmail");
				const stepChoice = document.getElementById("stepChoice");
				const stepRemembered = document.getElementById("stepRemembered");
				const emailForm = document.getElementById("emailForm");
				const emailInput = document.getElementById("userEmail");
				const emailError = document.getElementById("emailError");
				const submitEmailBtn = document.getElementById("submitEmailBtn");

				const btnWeb = document.getElementById("btnWeb");
				const btnTelegram = document.getElementById("btnTelegram");
				const btnVK = document.getElementById("btnVK");
				const btnEmailEl = document.getElementById("btnEmail");

				function showStepChoice() {
					stepEmail.style.display = "none";
					stepChoice.style.display = "block";
					stepRemembered.style.display = "none";
					document.getElementById("email-submitted").style.display = "none";
					if (emailVerified && btnEmailEl) {
						btnEmailEl.style.display = "none";
					}
				}

				function openModal() {
					modal.style.display = "flex";
					// Небольшая задержка для запуска CSS transition
					setTimeout(() => {
						modal.style.opacity = "1";
						modalContent.style.transform = "translateY(0)";
					}, 10);
					emailInput.focus();
				}

				function closeModal() {
					modal.style.opacity = "0";
					modalContent.style.transform = "translateY(20px)";
					setTimeout(() => {
						modal.style.display = "none";
					}, 300);
				}

				btnOpenList.forEach(btn => btn.addEventListener("click", openModal));
				btnClose.addEventListener("click", closeModal);
				modal.addEventListener("click", (e) => {
					if (e.target === modal) closeModal();
				});

				// Автоматическое открытие (если переданы параметры)
				if (emailVerified && storedEmail && urlStep === "channels") {
					openModal();
					showStepChoice();
				} else if (emailVerified && storedEmail) {
					openModal();
					stepEmail.style.display = "none";
					stepChoice.style.display = "none";
					document.getElementById("email-submitted").style.display = "none";
					stepRemembered.style.display = "block";
					const rememberedEmailEl = document.getElementById("remembered-email-msg");
					if (rememberedEmailEl) rememberedEmailEl.textContent = storedEmail;
				} else if (urlStep === "channels") {
					openModal();
					showStepChoice();
				}

				// Обработка формы
				emailForm.addEventListener("submit", async (e) => {
					e.preventDefault();
					const email = emailInput.value.trim();
					const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

					if (!emailRegex.test(email)) {
						emailError.style.display = "block";
						return;
					}

					emailError.style.display = "none";
					const originalBtnText = submitEmailBtn.innerHTML;
					submitEmailBtn.innerHTML = "ОТПРАВКА...";
					submitEmailBtn.disabled = true;

					try {
						const res = await fetch(API_URL, {
							method: "POST",
							headers: { "Content-Type": "application/json" },
							body: JSON.stringify({
								isEmail: true,
								email: email,
								partner_id: partnerId,
								sessionId: currentSessionId,
							}),
						});
						const data = await res.json();
						localStorage.setItem("neurogen_email", email);
						localStorage.setItem("neurogen_email_submitted", "true");

						stepEmail.style.display = "none";
						stepChoice.style.display = "none";
						const emailSubmittedEl = document.getElementById("email-submitted");
						if (emailSubmittedEl) {
							emailSubmittedEl.style.display = "block";
							const emailMsgEl = document.getElementById("email-submitted-msg");
							if (emailMsgEl) emailMsgEl.textContent = email;
						}
					} catch (err) {
						console.log("API error, local save applied.");
						localStorage.setItem("neurogen_email", email);
						localStorage.setItem("neurogen_email_submitted", "true");
						
						stepEmail.style.display = "none";
						stepChoice.style.display = "none";
						const emailSubmittedEl = document.getElementById("email-submitted");
						if (emailSubmittedEl) {
							emailSubmittedEl.style.display = "block";
						}
					}
				});

				document.getElementById("btnProceedToChannels")?.addEventListener("click", () => {
					stepRemembered.style.display = "none";
					showStepChoice();
				});

				function encodeEmailForUrl(email) {
					if (!email) return "";
					return btoa(email).replace(/\+/g, "-").replace(/\//g, "_").replace(/=/g, "");
				}

				// Обработка кликов по каналам
				btnTelegram.addEventListener("click", () => {
					const email = emailInput.value.trim() || storedEmail;
					const encEmail = email ? encodeEmailForUrl(email) : "noemail";
					// Используем безопасный разделитель __
					const startPayload = `${partnerId}__${currentSessionId}__${encEmail}`;
					window.open(`https://t.me/${refBot}?start=${startPayload}`, "_blank");
				});

				btnVK.addEventListener("click", () => {
					const email = emailInput.value.trim() || storedEmail;
					const encEmail = email ? encodeEmailForUrl(email) : "noemail";
					// Используем безопасный разделитель __
					const startPayload = `${partnerId}__${currentSessionId}__${encEmail}`;
					window.open(`${VK_COMMUNITY_URL}?ref=${startPayload}`, "_blank");
				});

				btnWeb.addEventListener("click", () => {
					const email = emailInput.value.trim() || storedEmail;
					// Добавляем email в URL для Web-чата
					let url = `${WEB_CHAT_URL}?ref=${partnerId}&session_id=${currentSessionId}`;
					if (email) {
						url += `&email=${encodeURIComponent(email)}`;
					}
					window.open(url, "_blank");
				});

				btnEmailEl.addEventListener("click", () => {
					const email = emailInput.value.trim();
					stepChoice.innerHTML = `
						<div style="text-align: center;">
							<div style="width: 64px; height: 64px; background: linear-gradient(to bottom right, #4ade80, #10b981); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; margin: 0 auto 16px;">📧</div>
							<h3 style="font-size: 24px; font-weight: bold; color: white; margin: 0 0 8px 0;">Письмо уже в пути!</h3>
							<p style="font-size: 14px; color: #888;">Мы отправили пошаговую инструкцию на <b>${email || "твой email"}</b>.</p>
						</div>`;
				});
			});
		</script>
	</body>
</html>